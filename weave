def cmd_hook_session(args):
    """SessionStart hook: print compact state into Claude's context."""
    root = find_root()
    if not root:
        return
    g = load_graph(root)
    nodes = g["nodes"]
    p = paths(root)
    # Memory tiers: skip archived nodes entirely, surface pinned nodes
    # before the routine status. Keeps the hook payload lean as the graph grows.
    def _live(n):
        return n.get("tier", "active") != "archive"
    live = [n for n in nodes.values() if _live(n)]
    pinned = [n for n in live if n.get("tier") == "pinned"]
    tasks = [n for n in live if n["type"] == "task"]
    doing = [n for n in tasks if n.get("status") == "doing"]
    blocked = [n for n in tasks if n.get("status") == "blocked"]
    todo = [n for n in tasks if n.get("status") == "todo"]
    qs = [n for n in live
          if n["type"] == "question" and n.get("status") != "resolved"]
    inbox = _inbox_files(root)
    fid = get_focus(root)

    # Rollup: which files Claude touched since the last SessionStart fire.
    # PostToolUse stays silent per-edit; this surfaces the delta once.
    seen_session_fp = os.path.join(p["weave"], ".seen_session")
    last_ts = None
    if os.path.exists(seen_session_fp):
        try:
            last_ts = json.load(open(seen_session_fp)).get("ts")
        except Exception:
            pass
    try:
        json.dump({"ts": now()}, open(seen_session_fp, "w"))
    except Exception:
        pass
    touched = []
    if last_ts:
        touched = [n for n in nodes.values()
                   if n.get("type") == "file"
                   and n.get("author") == "claude"
                   and n.get("updated", "") > last_ts]

    lines = ["[weave] shared project graph: .weave/graph.json  "
             "(%d nodes, rev %d)" % (len(nodes), g["meta"].get("rev", 0))]
    if touched:
        names = ", ".join(n.get("title", "?") for n in touched[:5])
        more = " (+%d more)" % (len(touched) - 5) if len(touched) > 5 else ""
        lines.append("  since last session: %d file(s) touched - %s%s" % (
            len(touched), names, more))
    if fid and fid in nodes:
        lines.append("  focus plan: %s (%s)" % (nodes[fid]["title"], fid))
    if pinned:
        lines.append("  pinned: " + "; ".join(
            "%s (%s)" % (n.get("title", ""), n["id"]) for n in pinned[:5]))
    if doing:
        lines.append("  in progress: " + "; ".join(
            "%s (%s)" % (n["title"], n["id"]) for n in doing[:5]))
    if blocked:
        lines.append("  blocked: " + "; ".join(
            "%s (%s)" % (n["title"], n["id"]) for n in blocked[:5]))
    if todo:
        lines.append("  todo: %d task(s)" % len(todo))
    if qs:
        lines.append("  open questions: " + "; ".join(
            "%s (%s)" % (n["title"], n["id"]) for n in qs[:5]))
    if inbox:
        lines.append("  inbox: %d unread - run `weave inbox`" % len(inbox))

    # context routing: reading list for the focus node and active tasks
    route_for = []
    if fid and fid in nodes:
        route_for.append(fid)
    for n in doing[:3]:
        if n["id"] not in route_for:
            route_for.append(n["id"])
    emitted = False
    for rid in route_for:
        rl = reading_list(g, rid)
        if not rl:
            continue
        if not emitted:
            lines.append("  -- reading lists (load these for the work) --")
            emitted = True
        paths_str = ", ".join(p for p, _ in rl[:12])
        more = "  (+%d more)" % (len(rl) - 12) if len(rl) > 12 else ""
        lines.append("  read for %s: %s%s" % (
            nodes[rid]["title"], paths_str, more))
    if route_for and not emitted:
        lines.append("  tip: attach files to tasks (`weave attach <task> "
                      "<paths>`) so reading lists route automatically.")

    # sibling projects: mention up to 3 other recently-touched weave projects
    try:
        idx = _load_global_index()
        root_abs = os.path.abspath(root)
        siblings = [pp for pp in idx.get("projects", [])
                    if os.path.abspath(pp.get("path", "")) != root_abs
                    and os.path.isdir(os.path.join(pp.get("path", ""),
                                                    WEAVE_DIRNAME))]
        siblings.sort(key=lambda pp: pp.get("last_seen", ""), reverse=True)
        if siblings:
            names = ", ".join(pp.get("name", "?") for pp in siblings[:3])
            extra = " (+%d more)" % (len(siblings) - 3) if len(siblings) > 3 else ""
            lines.append("  sibling weave projects: " + names + extra +
                          " - `weave projects`")
    except Exception:
        pass

    lines.append("  maintain it: `weave add/set/link/attach`, "
                 "`weave context <task>`. See CLAUDE.md weave section.")
    print("\n".join(lines))


def cmd_hook_postuse(args):
    """PostToolUse hook: auto-register files Claude writes/edits."""
    root = find_root()
    if not root:
        return
    try:
        payload = json.load(sys.stdin)
    except Exception:
        return
    ti = payload.get("tool_input", {}) or {}
    fp = ti.get("file_path") or ti.get("path")
    if not fp:
        return
    try:
        rel = os.path.relpath(os.path.abspath(fp), root)
    except Exception:
        return
    if rel.startswith("..") or rel.startswith(WEAVE_DIRNAME):
        return
    if os.path.splitext(rel)[1].lower() not in SCAN_EXTS:
        return
    g = load_graph(root)
    nid = upsert_file_node(g, root, rel, "claude")
    fid = get_focus(root)
    if fid and fid in g["nodes"]:
        add_edge(g, fid, nid, "produces")
    save_graph(root, g)


def cmd_hook_pretool(args):
    """PreToolUse hook: before each tool call, surface graph changes the
    human made since Claude last looked - so Claude sees mid-task edits.

    Emits JSON with hookSpecificOutput.additionalContext when (and only when)
    something changed, keeping injected context tiny."""
    root = find_root()
    if not root:
        return
    p = paths(root)
    seen_fp = os.path.join(p["weave"], ".seen_rev")
    g = load_graph(root)
    rev = g["meta"].get("rev", 0)

    last_rev = -1
    last_log = 0
    if os.path.exists(seen_fp):
        try:
            prev = json.load(open(seen_fp))
            last_rev = prev.get("rev", -1)
            last_log = prev.get("log_len", 0)
        except Exception:
            pass

    log = g.get("log", [])
    # write current marker first so we never double-report
    try:
        json.dump({"rev": rev, "log_len": len(log)}, open(seen_fp, "w"))
    except Exception:
        pass

    if last_rev < 0 or rev == last_rev:
        return  # first call this session, or nothing changed

    # report only human-authored events since last look - that is what
    # Claude could not otherwise know about. Inbox/signals are already
    # surfaced at SessionStart; only re-surface them alongside a fresh
    # human event, otherwise we'd nag on every tool call for the rest of
    # the session.
    fresh = [ev for ev in log[last_log:] if ev.get("actor") == "human"]
    if not fresh:
        return
    inbox = _inbox_files(root)
    signals = [n for n in g["nodes"].values()
               if "for-claude" in n.get("tags", [])
               and n.get("status") != "resolved"]

    parts = ["[weave] the human changed the shared graph while you were "
             "working:"]
    for ev in fresh[-8:]:
        parts.append("  - " + ev.get("action", ""))
    for n in signals[:5]:
        parts.append("  ! flagged for you: %s (%s) - %s"
                      % (n.get("title", ""), n.get("id"),
                         (n.get("body", "") or "")[:120]))
    if inbox:
        parts.append("  - inbox: %d unread message(s); run `weave inbox`"
                     % len(inbox))
    parts.append("Reconsider current work in light of this if relevant.")

    out = {"hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": "\n".join(parts)}}
    print(json.dumps(out))


