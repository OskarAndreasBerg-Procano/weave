      return;
    }
    m.innerHTML="";
    items.forEach(pp=>{
      const r=document.createElement("div");
      const liveBadge=pp.serve_port?" <span class='ps' style='color:var(--task-done)'>● live</span>":"";
      r.className="projrow"+(pp.is_self?" self":"");
