def serve(root, port, do_open):
    state = {"root": root}

    class Handler(BaseHTTPRequestHandler):
        def log_message(self, *a):
            pass

        def _send(self, code, body, ctype="application/json"):
            data = body.encode("utf-8") if isinstance(body, str) else body
            self.send_response(code)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(data)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(data)

        def do_GET(self):
            path = self.path.split("?")[0]
            if path == "/":
                self._send(200, render_html(mode="live", data=None),
                           "text/html; charset=utf-8")
            elif path == "/api/graph":
                g = load_graph(state["root"])
                rev = None
                if "?" in self.path:
                    q = self.path.split("?", 1)[1]
                    for kv in q.split("&"):
                        if kv.startswith("rev="):
                            try:
                                rev = int(kv[4:])
                            except Exception:
                                rev = None
                if rev is not None and rev == g["meta"].get("rev"):
                    self._send(200, json.dumps(
                        {"unchanged": True, "rev": rev}))
                else:
                    g["focus"] = get_focus(state["root"])
                    self._send(200, json.dumps(g))
            elif path == "/api/projects":
                # cross-project nav. Lists sibling weave projects with
                # stats; probes any .serve marker's port to filter out
                # stale markers from hard-killed serves. Sorted live-first,
                # then by last_seen desc.
                idx = _load_global_index()
                here = os.path.abspath(state["root"])
                out = []
                for pp in idx.get("projects", []):
                    p_abs = os.path.abspath(pp.get("path", ""))
                    if not os.path.isdir(os.path.join(p_abs, WEAVE_DIRNAME)):
                        continue
                    info = {"path": p_abs,
                            "name": pp.get("name", ""),
                            "last_seen": pp.get("last_seen", ""),
                            "is_self": p_abs == here}
                    try:
                        gp = os.path.join(p_abs, WEAVE_DIRNAME, "graph.json")
                        gg = json.load(open(gp, encoding="utf-8"))
                        info["rev"] = gg["meta"].get("rev", 0)
                        info["nodes"] = len(gg.get("nodes", {}))
                    except Exception:
                        info["rev"], info["nodes"] = 0, 0
                    sfp = os.path.join(p_abs, WEAVE_DIRNAME, ".serve")
                    if os.path.exists(sfp):
                        try:
                            s = json.load(open(sfp, encoding="utf-8"))
                            port = s.get("port")
                            if port and _port_alive(port):
                                info["serve_port"] = port
                            else:
                                # self-heal stale markers older than ~5 min.
                                # Long enough that a slow startup or brief
                                # network blip won't wipe a real serve;
                                # short enough to keep the dropdown clean.
                                age = time.time() - os.path.getmtime(sfp)
                                if age > 300:
                                    try:
                                        os.remove(sfp)
                                    except OSError:
                                        pass
                        except Exception:
                            pass
                    out.append(info)
                # Sort live-first, then most-recently-seen first. Python
                # sort is stable, so two passes (least-significant first):
                out.sort(key=lambda x: x.get("last_seen", ""), reverse=True)
                out.sort(key=lambda x: 0 if x.get("serve_port") else 1)
                self._send(200, json.dumps({"projects": out}))
            elif path == "/api/search":
                # Free-text search powering the workspace deep/global search.
                # Query params: q=<query>, global=1, n=<max>.
                qp = {}
                if "?" in self.path:
                    for kv in self.path.split("?", 1)[1].split("&"):
                        if "=" in kv:
                            k, v = kv.split("=", 1)
                            qp[k] = v
                from urllib.parse import unquote_plus
                q = unquote_plus(qp.get("q", ""))
                if not q:
                    self._send(200, json.dumps({"matches": []}))
                    return
                limit = max(1, min(200, int(qp.get("n", "30"))))
                want_global = qp.get("global") in ("1", "true", "yes")
                matches = []
                total = 0
                if want_global:
                    idx = _load_global_index()
                    for pp in idx.get("projects", []):
                        gp = os.path.join(pp.get("path", ""),
                                          WEAVE_DIRNAME, "graph.json")
                        if not os.path.exists(gp):
                            continue
                        try:
                            gg = json.load(open(gp, encoding="utf-8"))
                        except Exception:
                            continue
                        sfp = os.path.join(pp.get("path", ""),
                                           WEAVE_DIRNAME, ".serve")
                        port = None
                        if os.path.exists(sfp):
                            try:
                                ss = json.load(open(sfp, encoding="utf-8"))
                                p2 = ss.get("port")
                                if p2 and _port_alive(p2):
                                    port = p2
                            except Exception:
                                pass
                        rows = _search_graph(gg, q)
                        total += len(rows)
                        per_proj = max(1, limit // 4)
                        for nid, n in rows[:per_proj]:
                            if len(matches) >= limit:
                                break
                            matches.append({
                                "id": nid, "type": n.get("type"),
                                "title": n.get("title", ""),
                                "status": n.get("status", ""),
                                "project": pp.get("name", ""),
                                "project_path": pp.get("path", ""),
                                "serve_port": port,
                            })
                else:
                    g = load_graph(state["root"])
                    rows = _search_graph(g, q)
                    total = len(rows)
                    for nid, n in rows[:limit]:
                        matches.append({
                            "id": nid, "type": n.get("type"),
                            "title": n.get("title", ""),
                            "status": n.get("status", ""),
                        })
                self._send(200, json.dumps({"matches": matches,
                                            "total": total,
                                            "global": want_global,
                                            "query": q}))
            elif path == "/api/history":
                # Snapshot history powering the workspace undo / history UI.
                vdir = paths(state["root"])["versions"]
                files = _list_versions(vdir)
                cur_rev = load_graph(state["root"]
                                     )["meta"].get("rev", 0)
                # parse ?n=N (default 30, cap 50)
                n = 30
                if "?" in self.path:
                    for kv in self.path.split("?", 1)[1].split("&"):
                        if kv.startswith("n="):
                            try:
                                n = max(1, min(50, int(kv[2:])))
                            except Exception:
                                pass
                out = []
                for f in list(reversed(files))[:n]:
                    rev = int(f.split(".")[0])
                    fp = os.path.join(vdir, f)
                    try:
                        gg = json.load(open(fp, encoding="utf-8"))
                        log = gg.get("log", [])
                        last = log[-1].get("action", "") if log else ""
                        out.append({"rev": rev,
                                     "ts": gg["meta"].get("updated", ""),
                                     "last": last[:100],
                                     "nodes": len(gg.get("nodes", {})),
                                     "is_current": rev == cur_rev})
                    except Exception:
                        pass
                self._send(200, json.dumps({"history": out,
                                            "current": cur_rev}))
            elif path == "/api/file":
                # Read tracked file content for the side-panel preview.
                # Safety: path must be a file-node in the graph, resolve
                # under the project root, refuse oversize / binary blobs.
                qp = {}
                if "?" in self.path:
                    for kv in self.path.split("?", 1)[1].split("&"):
                        if "=" in kv:
                            k, v = kv.split("=", 1)
                            qp[k] = v
                from urllib.parse import unquote_plus
                nid = unquote_plus(qp.get("id", ""))
                if not nid:
                    self._send(400, json.dumps({"error": "missing id"}))
                    return
                g = load_graph(state["root"])
                n = g["nodes"].get(nid)
                if not n:
                    self._send(404, json.dumps({"error": "no node"}))
                    return
                ntype = n.get("type")
                if ntype == "folder":
                    kids = []
                    for e in g["edges"]:
                        if e["from"] == nid and e["rel"] == "contains":
                            c = g["nodes"].get(e["to"])
                            if c:
                                kids.append({
                                    "id": c["id"],
                                    "type": c.get("type"),
                                    "title": c.get("title", ""),
                                    "path": c.get("path", "")})
                    kids.sort(key=lambda k: (
                        0 if k["type"] == "folder" else 1,
                        (k["path"] or k["title"]).lower()))
                    self._send(200, json.dumps({
                        "folder": True,
                        "path": n.get("path", ""),
                        "children": kids}))
                    return
                if ntype != "file":
                    self._send(400, json.dumps({
                        "error": "node is not a file or folder"}))
                    return
                rel = n.get("path", "")
                if not rel:
                    self._send(400, json.dumps({"error":
                                                "node has no path"}))
                    return
                root_abs = os.path.realpath(state["root"])
                target = os.path.realpath(os.path.join(root_abs, rel))
                if not (target == root_abs or
                        target.startswith(root_abs + os.sep)):
                    self._send(403, json.dumps({
                        "error": "path escapes project root"}))
                    return
                if not os.path.exists(target):
                    self._send(200, json.dumps({
                        "missing": True, "path": rel}))
                    return
                if not os.path.isfile(target):
                    self._send(400, json.dumps({
                        "error": "not a regular file"}))
                    return
                try:
                    st = os.stat(target)
                except OSError as e:
                    self._send(500, json.dumps({"error": str(e)}))
                    return
                size = st.st_size
                MAX_DISPLAY = 200_000
                HARD_MAX = 10_000_000
                if size > HARD_MAX:
                    self._send(200, json.dumps({
                        "too_big": True, "size": size, "path": rel}))
                    return
                try:
                    with open(target, "rb") as f:
                        head = f.read(MAX_DISPLAY + 1)
                except OSError as e:
                    self._send(500, json.dumps({"error": str(e)}))
                    return
                # binary sniff on the first 4KB - cheap and good enough
                binary = b"\x00" in head[:4096]
                truncated = len(head) > MAX_DISPLAY
                head = head[:MAX_DISPLAY]
                if binary:
                    self._send(200, json.dumps({
                        "binary": True, "size": size, "path": rel,
                        "mtime": int(st.st_mtime),
                        "abspath": target}))
                    return
                try:
                    text = head.decode("utf-8")
                except UnicodeDecodeError:
                    text = head.decode("utf-8", "replace")
                self._send(200, json.dumps({
                    "content": text, "size": size, "path": rel,
                    "mtime": int(st.st_mtime),
                    "truncated": truncated,
                    "abspath": target}))
            elif path == "/api/stream":
                self._stream()
            else:
                self._send(404, "{}")

        def _stream(self):
            """Server-sent events: push the graph the instant the file
            changes. Watches mtime of graph.json + focus marker."""
            try:
                self.send_response(200)
                self.send_header("Content-Type", "text/event-stream")
                self.send_header("Cache-Control", "no-store")
                self.send_header("Connection", "keep-alive")
                self.send_header("X-Accel-Buffering", "no")
                self.end_headers()
            except Exception:
                return
            p = paths(state["root"])
            last_sig = None
            last_beat = time.time()

            def sig():
                s = []
                for fp in (p["graph"], p["focus"]):
                    try:
                        s.append(os.stat(fp).st_mtime_ns)
                    except OSError:
                        s.append(0)
                return tuple(s)

            try:
                while True:
                    cur = sig()
                    if cur != last_sig:
                        last_sig = cur
                        g = load_graph(state["root"])
                        g["focus"] = get_focus(state["root"])
                        msg = ("event: graph\ndata: %s\n\n"
                               % json.dumps(g))
                        self.wfile.write(msg.encode("utf-8"))
                        self.wfile.flush()
                        last_beat = time.time()
                    elif time.time() - last_beat > 15:
                        self.wfile.write(b": keepalive\n\n")
                        self.wfile.flush()
                        last_beat = time.time()
                    time.sleep(0.4)
            except (BrokenPipeError, ConnectionResetError, OSError):
                return

        def do_POST(self):
            if self.path != "/api/op":
                self._send(404, "{}")
                return
            try:
                ln = int(self.headers.get("Content-Length", 0))
                req = json.loads(self.rfile.read(ln) or b"{}")
            except Exception:
                self._send(400, json.dumps({"error": "bad request"}))
                return
            try:
                result = self._apply(req)
                self._send(200, json.dumps(result))
            except Exception as e:
                self._send(500, json.dumps({"error": str(e)}))

        def _apply(self, req):
            root = state["root"]
            g = load_graph(root)
            op = req.get("op")
            if op == "add_node":
                nid = new_id()
                t = req.get("type", "note")
                g["nodes"][nid] = {
                    "id": nid, "type": t, "title": req.get("title", ""),
                    "body": req.get("body", ""),
                    "status": req.get("status", "") or (
                        "todo" if t == "task" else
                        "open" if t == "question" else ""),
                    "tags": req.get("tags", []), "path": "",
                    "author": "human", "created": now(), "updated": now()}
                log_event(g, "human", "add %s: %s" % (
                    t, req.get("title", "")), nid)
                if req.get("parent"):
                    add_edge(g, nid, req["parent"],
                             req.get("rel", "relates_to"))
                save_graph(root, g)
                return {"ok": True, "id": nid}
            if op == "update_node":
                nid = req["id"]
                n = g["nodes"].get(nid)
                if not n:
                    return {"error": "no node"}
                for k in ("title", "body", "status"):
                    if k in req:
                        n[k] = req[k]
                if "tags" in req:
                    n["tags"] = req["tags"]
                if "tier" in req:
                    if req["tier"] not in TIERS:
                        return {"error": "invalid tier"}
                    n["tier"] = req["tier"]
                n["updated"] = now()
                log_event(g, "human", "edit %s" % nid, nid)
                save_graph(root, g)
                return {"ok": True}
            if op == "del_node":
                nid = req["id"]
                g["nodes"].pop(nid, None)
                g["edges"] = [e for e in g["edges"]
                              if e["from"] != nid and e["to"] != nid]
                log_event(g, "human", "delete %s" % nid)
                save_graph(root, g)
                return {"ok": True}
            if op == "add_edge":
                add_edge(g, req["from"], req["to"],
                         req.get("rel", "relates_to"))
                log_event(g, "human", "link %s->%s" % (
                    req["from"], req["to"]))
                save_graph(root, g)
                return {"ok": True}
            if op == "del_edge":
                g["edges"] = [e for e in g["edges"] if not (
                    e["from"] == req["from"] and e["to"] == req["to"]
                    and e["rel"] == req.get("rel", e["rel"]))]
                save_graph(root, g)
                return {"ok": True}
            if op == "focus":
                set_focus(root, req.get("id") or None)
                return {"ok": True}
            if op == "undo":
                # workspace undo: same semantics as `weave undo [--to <rev>]`
                p = paths(root)
                vdir = p["versions"]
                files = _list_versions(vdir)
                if not files:
                    return {"error": "no version history yet"}
                cur = load_graph(root)
                cur_rev = cur["meta"].get("rev", 0)
                to = req.get("to")
                if to is not None:
                    target = "%07d.json" % int(to)
                    if target not in files:
                        return {"error": "no snapshot for rev %d" % int(to)}
                else:
                    target = None
                    for f in reversed(files):
                        if int(f.split(".")[0]) < cur_rev:
                            target = f
                            break
                    if target is None:
                        return {"error":
                                "no earlier snapshot to undo to"}
                gg = json.load(open(os.path.join(vdir, target),
                                    encoding="utf-8"))
                restored_rev = gg["meta"].get("rev", 0)
                gg["meta"]["rev"] = cur_rev
                log_event(gg, "human",
                          "undo: restored rev %d" % restored_rev)
                save_graph(root, gg)
                return {"ok": True, "restored_rev": restored_rev,
                        "new_rev": gg["meta"]["rev"],
                        "nodes": len(gg["nodes"]),
                        "edges": len(gg["edges"])}
            if op == "sync":
                # mirror cmd_sync but driven by JSON args. Returns the
                # summary counts so the workspace can toast.
                class _A:
                    pass
                a = _A()
                a.scan = bool(req.get("scan"))
                a.tree = bool(req.get("tree"))
                a.prune_missing = bool(req.get("prune_missing"))
                buf = io.StringIO()
                with contextlib.redirect_stdout(buf):
                    cmd_sync(a)
                return {"ok": True, "summary": buf.getvalue().strip()}
            if op == "commit":
                # link a git commit (or range) - mirrors `weave commit`.
                class _A:
                    pass
                a = _A()
                a.sha = req.get("sha")
                a.since = req.get("since")
                buf = io.StringIO()
                err_buf = io.StringIO()
                try:
                    with contextlib.redirect_stdout(buf), \
                         contextlib.redirect_stderr(err_buf):
                        cmd_commit(a)
                except SystemExit as e:
                    return {"error": (err_buf.getvalue().strip()
                                       or "commit failed")}
                return {"ok": True, "summary": buf.getvalue().strip()}
            return {"error": "unknown op"}

    class _QuietServer(ThreadingHTTPServer):
        """ThreadingHTTPServer that doesn't dump a traceback every time the
        browser drops a connection (tab close, refresh during an SSE stream,
        etc). Those errors are expected, not bugs - swallow them silently
        so stderr stays readable and harnesses don't flag the process."""
        def handle_error(self, request, client_address):
            etype, e = sys.exc_info()[:2]
            if etype and issubclass(etype, (BrokenPipeError,
                                            ConnectionAbortedError,
                                            ConnectionResetError)):
                return
            super().handle_error(request, client_address)

    httpd = _QuietServer(("127.0.0.1", port), Handler)
    url = "http://127.0.0.1:%d/" % port
    # Drop a .serve marker so OTHER weave workspaces can list us + offer
    # to open this project in a new tab. Removed on clean shutdown.
    serve_fp = os.path.join(paths(root)["weave"], ".serve")
    try:
        with open(serve_fp, "w") as f:
            json.dump({"port": port, "pid": os.getpid(),
                       "started": now()}, f)
    except Exception:
        pass
    print("weave workspace live at %s   (Ctrl-C to stop)" % url)
    if do_open:
        try:
            webbrowser.open(url)
        except Exception:
            pass
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nweave: stopped")
        httpd.shutdown()
    finally:
        try:
            os.remove(serve_fp)
        except Exception:
            pass


