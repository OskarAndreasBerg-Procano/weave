# force utf-8 on the std streams so middle-dot separators and other
# non-ascii output don't mojibake on Windows consoles (cp1252 default).
for _s in (sys.stdout, sys.stderr, sys.stdin):
    try:
        _s.reconfigure(encoding="utf-8")
    except Exception:
        pass

