  // memory tier (pin / archive)
  if(live){
    const tierSel=selectEl(["active","pinned","archive"],
      n.tier||"active",
      v=>op({op:"update_node",id,tier:v}));
    b.appendChild(field("memory tier",tierSel));
  }else if((n.tier||"active")!=="active"){
    b.appendChild(field("memory tier",textEl(n.tier)));
  }
  // body
  if(live){
    const ta=document.createElement("textarea"); ta.value=n.body||"";
    ta.onblur=()=>{ if(ta.value!==(n.body||""))
      op({op:"update_node",id,body:ta.value}); };
    b.appendChild(field("body / notes",ta));
  }else{
    b.appendChild(field("body",textEl(n.body||"\u2014")));
  }
  b.appendChild(field("updated",textEl(n.updated||"")));

  // neighbors
  const out=graph.edges.filter(e=>e.from===id);
  const inc=graph.edges.filter(e=>e.to===id);
  if(out.length||inc.length){
    const wrap=document.createElement("div");
    out.forEach(e=>wrap.appendChild(nbrEl(e.rel+" \u2192",e.to)));
    inc.forEach(e=>wrap.appendChild(nbrEl("\u2190 "+e.rel,e.from)));
    b.appendChild(field("connections",wrap));
  }

  // context routing: reading list for plan/task/milestone
  if(["plan","task","milestone"].includes(n.type)){
    const rl=readingList(id);
    const wrap=document.createElement("div");
    if(rl.length){
      rl.forEach(r=>{
        const row=document.createElement("div"); row.className="nbr";
        row.innerHTML="<span class='pin' style='background:"+
          cssVar("--file")+"'></span><span style='flex:1'>"+
          esc(r.path)+"</span>";
        if(live&&r.direct){
          const x=document.createElement("span");
          x.textContent="\u00d7"; x.style.cssText=
            "color:var(--dim);cursor:pointer;padding:0 3px";
          x.title="detach"; x.onclick=ev=>{ev.stopPropagation();
            op({op:"del_edge",from:id,to:r.tid,rel:"reads"});};
          row.appendChild(x);
        }else if(!r.direct){
          const tag=document.createElement("span");
          tag.className="muted"; tag.style.fontSize="9px";
          tag.textContent="inherited"; row.appendChild(tag);
        }
        wrap.appendChild(row);
      });
    }else{
      const e=document.createElement("div"); e.className="muted";
      e.style.fontSize="11px";
      e.textContent="no reading list \u2014 attach files Claude should load";
      wrap.appendChild(e);
    }
    if(live){
      const sel=document.createElement("select");
      sel.style.marginTop="6px";
      const ph=document.createElement("option");
      ph.value=""; ph.textContent="+ attach file / folder...";
      sel.appendChild(ph);
      const attached=new Set(graph.edges.filter(
        e=>e.from===id&&e.rel==="reads").map(e=>e.to));
      Object.values(graph.nodes)
        .filter(x=>(x.type==="file"||x.type==="folder")&&!attached.has(x.id))
        .sort((a,b)=>(a.path||a.title).localeCompare(b.path||b.title))
        .forEach(x=>{const o=document.createElement("option");
          o.value=x.id;o.textContent=(x.type==="folder"?"\ud83d\udcc1 ":"")+
            (x.path||x.title);sel.appendChild(o);});
      sel.onchange=()=>{ if(sel.value)
        op({op:"add_edge",from:id,to:sel.value,rel:"reads"}); };
      wrap.appendChild(sel);
    }
    b.appendChild(field("reading list \u00b7 what Claude loads",wrap));
  }

  const foot=document.getElementById("pFoot"); foot.innerHTML="";
  if(live){
    const f=document.createElement("button"); f.className="btn";
    f.textContent=(focusId===id)?"unfocus":"set focus";
    f.onclick=()=>op({op:"focus",id:focusId===id?null:id});
    foot.appendChild(f);
    const flagged=(n.tags||[]).includes("for-claude");
    const fl=document.createElement("button"); fl.className="btn";
    fl.textContent=flagged?"clear flag":"flag for Claude";
    if(flagged)fl.style.color=cssVar("--accent");
    fl.title="surfaces this node in Claude's next tool-call hook";
    fl.onclick=()=>{
      const tags=(n.tags||[]).slice();
      const i=tags.indexOf("for-claude");
      if(i>=0)tags.splice(i,1); else tags.push("for-claude");
      op({op:"update_node",id,tags});
    };
    foot.appendChild(fl);
    const del=document.createElement("button"); del.className="btn";
    del.textContent="delete"; del.style.color=cssVar("--task-blocked");
    del.onclick=()=>{ if(confirm("delete "+n.title+"?"))
      op({op:"del_node",id}); };
    foot.appendChild(del);
  }
  const cp=document.createElement("button"); cp.className="btn";
  cp.textContent="copy id"; cp.onclick=()=>navigator.clipboard?.writeText(id);
  foot.appendChild(cp);
}
function field(lbl,el){
  const r=document.createElement("div"); r.className="row";
  const l=document.createElement("div"); l.className="lbl"; l.textContent=lbl;
  r.appendChild(l); r.appendChild(el); return r;
}
function childrenVia(id,rel){
  return graph.edges.filter(e=>e.from===id&&e.rel===rel).map(e=>e.to);
}
function expandPaths(id,seen){
  seen=seen||new Set();
  if(seen.has(id)||!graph.nodes[id])return [];
  seen.add(id);
  const n=graph.nodes[id];
  if(n.type==="file")return n.path?[n.path]:[];
  if(n.type==="folder"){
    let o=[]; childrenVia(id,"contains").forEach(c=>o=o.concat(expandPaths(c,seen)));
    return o;
  }
  let o=[]; childrenVia(id,"reads").forEach(c=>o=o.concat(expandPaths(c,seen)));
  return o;
}
function readingList(id){
  // {path,via,tid,direct}; inherited entries come from parent plans
  const seen=new Set(), out=[];
  function addFrom(srcId,direct){
    childrenVia(srcId,"reads").forEach(tid=>{
      const label=(graph.nodes[tid]||{}).title||tid;
      expandPaths(tid).forEach(p=>{
        if(!seen.has(p)){seen.add(p);
          out.push({path:p,via:label,tid:tid,direct:direct});}
      });
    });
  }
  graph.edges.filter(e=>e.from===id&&e.rel==="implements")
    .forEach(e=>addFrom(e.to,false));
  addFrom(id,true);
  return out;
}
function textEl(t){const d=document.createElement("div");
  d.className="val"; d.textContent=t; return d;}
function selectEl(opts,val,cb){
  const s=document.createElement("select");
  opts.forEach(o=>{const e=document.createElement("option");
    e.value=o;e.textContent=o;if(o===val)e.selected=true;s.appendChild(e);});
  s.onchange=()=>cb(s.value); return s;
}
function nbrEl(rel,id){
  const n=graph.nodes[id]; const d=document.createElement("div");
