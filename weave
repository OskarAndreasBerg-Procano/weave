// ---- keyboard shortcuts ----
const SHORTCUTS=[
  ["/","focus search"],["n","new node"],["z","zoom to fit"],
  ["t","toggle folder tree panel"],
  ["u","undo last graph change"],["h","open history (snapshot list)"],
  ["g","link git commit(s)"],
  ["r","re-run layout"],["f","toggle focus on selected node"],
  ["esc","close panel / dialog"],["?","this help"],
  ["shift-drag","node \u2192 node to create a link"],
  ["double-click","empty space to add a node"],
];
function showHelp(on){
  const ov=document.getElementById("help");
  if(on){
    const g=document.getElementById("hgrid"); g.innerHTML="";
    SHORTCUTS.forEach(([k,d])=>{
      const kk=document.createElement("div"); kk.className="k";
      kk.innerHTML="<kbd>"+esc(k)+"</kbd>";
      const dd=document.createElement("div"); dd.className="d";
      dd.textContent=d;
      g.appendChild(kk); g.appendChild(dd);
    });
  }
  ov.classList.toggle("open",on);
}
function anyOverlayOpen(){
  return document.getElementById("add").classList.contains("open")||
    document.getElementById("help").classList.contains("open")||
    document.getElementById("link").classList.contains("open")||
    document.getElementById("history").classList.contains("open")||
    document.getElementById("commit").classList.contains("open");
}
addEventListener("keydown",e=>{
  if(e.key==="Escape"){
    document.getElementById("add").classList.remove("open");
    document.getElementById("link").classList.remove("open");
    document.getElementById("help").classList.remove("open");
    document.getElementById("history").classList.remove("open");
    document.getElementById("commit").classList.remove("open");
    closeActions();
    closePanel(); return;
  }
  const typing=/^(INPUT|TEXTAREA|SELECT)$/.test(
    (e.target.tagName||""));
  if(typing||e.metaKey||e.ctrlKey||e.altKey)return;
  if(e.key==="/"){e.preventDefault();
    document.getElementById("search").focus();return;}
  if(e.key==="?"){showHelp(true);return;}
  if(anyOverlayOpen())return;
  if(e.key==="n"&&MODE==="live"){openAdd();}
  else if(e.key==="z"){fitView();alpha=Math.max(alpha,.05);}
  else if(e.key==="t"){toggleTree();}
  else if(e.key==="r"){for(const p of pos.values())p.fixed=false;alpha=1;}
  else if(e.key==="u"&&MODE==="live"){doUndo();}
  else if(e.key==="h"&&MODE==="live"){openHistory();}
  else if(e.key==="g"&&MODE==="live"){openCommit();}
  else if(e.key==="f"&&selected&&MODE==="live"){
    op({op:"focus",id:focusId===selected?null:selected});}
});

// ---- link dialog (shift-drag result) ----
function openLink(from,to){
  if(MODE!=="live"){op({});return;}
  const ov=document.getElementById("link");
  document.getElementById("lFrom").textContent=
    (graph.nodes[from]||{}).title||from;
  document.getElementById("lTo").textContent=
    (graph.nodes[to]||{}).title||to;
  const sel=document.getElementById("lRel"); sel.innerHTML="";
  RELS.forEach(r=>{const o=document.createElement("option");
    o.value=r;o.textContent=r;sel.appendChild(o);});
  // sensible default by node types
  const ft=(graph.nodes[from]||{}).type,tt=(graph.nodes[to]||{}).type;
  let def="relates_to";
  if(ft==="task"&&(tt==="plan"||tt==="milestone"))def="implements";
  else if(tt==="file"||tt==="folder")def="reads";
  sel.value=def;
  ov.dataset.from=from; ov.dataset.to=to;
  ov.classList.add("open");
}
document.getElementById("lSave").onclick=()=>{
  const ov=document.getElementById("link");
  op({op:"add_edge",from:ov.dataset.from,to:ov.dataset.to,
      rel:document.getElementById("lRel").value});
  ov.classList.remove("open");
};
document.getElementById("lCancel").onclick=()=>
  document.getElementById("link").classList.remove("open");

function openAdd(){
  const at=document.getElementById("aType"); at.innerHTML="";
  TYPES.forEach(t=>{const o=document.createElement("option");
    o.value=t;o.textContent=t;at.appendChild(o);});
  const ap=document.getElementById("aParent"); ap.innerHTML="";
  const none=document.createElement("option");
  none.value="";none.textContent="(none)";ap.appendChild(none);
  Object.values(graph.nodes)
    .filter(n=>n.type==="plan"||n.type==="milestone")
    .forEach(n=>{const o=document.createElement("option");
      o.value=n.id;o.textContent=n.type+": "+n.title;ap.appendChild(o);});
  document.getElementById("aTitle").value="";
  document.getElementById("aBody").value="";
  document.getElementById("add").classList.add("open");
  document.getElementById("aTitle").focus();
}
document.getElementById("aSave").onclick=()=>{
  const title=document.getElementById("aTitle").value.trim();
  if(!title){document.getElementById("aTitle").focus();return;}
  const req={op:"add_node",type:document.getElementById("aType").value,
    title,body:document.getElementById("aBody").value};
  const par=document.getElementById("aParent").value;
  if(par){req.parent=par;
    req.rel=req.type==="task"?"implements":"relates_to";}
  op(req);
  document.getElementById("add").classList.remove("open");
};

// ---- live sync ----
function op(req){
  if(MODE!=="live"){alert("read-only snapshot. run `weave serve` to edit.");
    return;}
  fetch("/api/op",{method:"POST",headers:{"Content-Type":"application/json"},
    body:JSON.stringify(req)})
    .then(r=>r.json()).then(()=>poll(true)).catch(()=>{});
}
let lastRev=-1, prevIds=null;
function poll(force){
  if(MODE!=="live")return;
  fetch("/api/graph?rev="+(force?-1:lastRev))
    .then(r=>r.json()).then(g=>{
      if(g.unchanged)return;
      applyGraph(g);
    }).catch(()=>setLive(false));
}
function applyGraph(g){
  // detect what changed vs previous state -> feed + pop animation
  if(prevIds){
    for(const id in g.nodes){
      if(!prevIds.has(id)){
        popIds.add(id); popClock.set(id,performance.now());
        feed("+ "+g.nodes[id].type+": "+g.nodes[id].title,
             g.nodes[id].author);
      }
    }
  }
  prevIds=new Set(Object.keys(g.nodes));
  lastRev=g.meta.rev;
  ingest(g);
}
function setLive(on,mode){
  document.getElementById("livedot").className="dot"+(on?"":" off");
  document.getElementById("livetxt").textContent=
    on?(mode||"live"):"offline";
}

// ---- activity feed ----
const popIds=new Set(), popClock=new Map();
function feed(text,who,nid){
  const el=document.getElementById("feed");
  if(!el)return;
  const row=document.createElement("div");
  row.className="frow"+(who==="claude"?" claude":"");
  const hasNode=nid && graph.nodes[nid];
  if(hasNode){
    row.dataset.nid=nid;
    row.style.cursor="pointer";
    row.title="jump to "+(graph.nodes[nid].title||nid);
  }
  const t=new Date().toLocaleTimeString().slice(0,5);
  row.innerHTML="<span class='ft'>"+t+"</span>"+
    "<span class='fw'>"+esc(who||"?")+"</span>"+
    "<span class='fx'>"+esc(text)+"</span>";
  if(hasNode){
    row.onclick=()=>{
      if(!graph.nodes[nid])return;        // node may have been removed
      selected=nid; openPanel(nid); centerOn(nid);
      cam.s=Math.max(cam.s,.9);
    };
  }
  el.insertBefore(row,el.firstChild);
  while(el.children.length>40)el.removeChild(el.lastChild);
  el.classList.add("flash");
  setTimeout(()=>el.classList.remove("flash"),600);
}
let lastLogLen=0;
function syncFeed(g){
  // surface graph log events authored by claude as they arrive
  const log=g.log||[];
  if(lastLogLen===0){lastLogLen=log.length;return;}
  for(let i=lastLogLen;i<log.length;i++){
    const ev=log[i];
    if(ev.actor==="claude")feed(ev.action,"claude",ev.node);
  }
  lastLogLen=log.length;
}

// ---- boot ----
if(MODE==="live"){
  setLive(true,"connecting");
  poll(true);
  let es=null, pollTimer=null;
  function startPoll(){
    if(pollTimer)return;
    pollTimer=setInterval(()=>poll(false),2000);
  }
  function connectSSE(){
    try{
      es=new EventSource("/api/stream");
      es.addEventListener("graph",e=>{
        if(pollTimer){clearInterval(pollTimer);pollTimer=null;}
        setLive(true,"live \u00b7 push");
        try{
          const g=JSON.parse(e.data);
          syncFeed(g); applyGraph(g);
        }catch(_){}
      });
      es.onerror=()=>{
        setLive(true,"live \u00b7 poll");
        startPoll();           // fall back; EventSource auto-retries
      };
    }catch(_){ startPoll(); }
  }
  connectSSE();
  startPoll();                 // safety net until first SSE frame
}else{
  document.getElementById("livedot").className="dot off";
  document.getElementById("livetxt").textContent="snapshot";
  ingest(BOOT||{meta:{},nodes:{},edges:[],log:[]});
}
requestAnimationFrame(step);
</script>
</body>
</html>
