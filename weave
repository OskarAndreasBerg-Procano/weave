<script>
const MODE = "__WEAVE_MODE__";
const BOOT = __WEAVE_DATA__;
const TYPES = ["plan","task","decision","file","folder","note","question",
  "milestone"];
const RELS = ["implements","depends_on","blocks","relates_to","supersedes",
  "produces","contains","answers","reads"];

function typeColor(n){
  if(n.type==="task"){
    return {todo:"--task-todo",doing:"--task-doing",done:"--task-done",
      blocked:"--task-blocked"}[n.status||"todo"]||"--task-todo";
  }
  return {plan:"--plan",file:"--file",folder:"--folder",
    decision:"--decision",note:"--note",
    question:"--question",milestone:"--milestone"}[n.type]||"--dim";
}
function cssVar(v){
  return getComputedStyle(document.documentElement).getPropertyValue(v).trim();
}

let graph={meta:{},nodes:{},edges:[],log:[]};
let focusId=null;
const pos=new Map();          // id -> {x,y,vx,vy,fixed}
const hidden=new Set(["archive"]);   // archived nodes hidden by default
let selected=null, hover=null, search="";
let cam={x:0,y:0,s:1}, alpha=1;
const cv=document.getElementById("cv"), ctx=cv.getContext("2d");
let drag=null, panning=null;

function resize(){
  cv.width=innerWidth*devicePixelRatio;
  cv.height=innerHeight*devicePixelRatio;
  cv.style.width=innerWidth+"px"; cv.style.height=innerHeight+"px";
}
addEventListener("resize",resize); resize();

let didFit=false;
let prevNodeCount=0;
function ingest(g){
  graph=g; focusId=g.focus||null;
  const ids=Object.keys(g.nodes);
  const R=Math.max(160,ids.length*14);
  ids.forEach((id,i)=>{
    if(!pos.has(id)){
      const a=i*2.399963;
      pos.set(id,{x:Math.cos(a)*R*Math.sqrt(i/ids.length+.05),
        y:Math.sin(a)*R*Math.sqrt(i/ids.length+.05),vx:0,vy:0,fixed:false});
    }
  });
  for(const id of [...pos.keys()]) if(!g.nodes[id]) pos.delete(id);
  alpha=Math.max(alpha,.7);
  renderChrome();
  document.getElementById("empty").classList.toggle("show",ids.length===0);
  if(selected && !g.nodes[selected]){selected=null;closePanel();}
  else if(selected) openPanel(selected);
  if(!didFit && ids.length){didFit=true;setTimeout(fitView,650);}
  // Big shrink (undo / prune / massive delete): re-fit so the human isn't
  // left staring at empty canvas where the graph used to extend.
  else if(prevNodeCount > 20 && ids.length < prevNodeCount * 0.6){
    setTimeout(fitView,300);
  }
  prevNodeCount=ids.length;
}

function isHidden(n){
  if(!n)return true;
  if(hidden.has(n.type))return true;
  if((n.tier||"active")==="archive" && hidden.has("archive"))return true;
  return false;
}
function fitView(){
  const vis=[...pos.entries()].filter(
    ([id])=>graph.nodes[id]&&!isHidden(graph.nodes[id]));
  if(!vis.length)return;
  let minx=1e9,miny=1e9,maxx=-1e9,maxy=-1e9;
  for(const [id,p] of vis){
    const r=nodeRadius(id)+18;
    minx=Math.min(minx,p.x-r); maxx=Math.max(maxx,p.x+r);
    miny=Math.min(miny,p.y-r); maxy=Math.max(maxy,p.y+r);
  }
  const w=maxx-minx,h=maxy-miny;
  const s=Math.min(2.4,Math.max(.2,
    Math.min((innerWidth-380)/w,(innerHeight-150)/h)));
  cam.s=s;
  cam.x=-((minx+maxx)/2)*s;
  cam.y=-((miny+maxy)/2)*s;
}

// ---- layout ----
function step(){
  if(alpha<.005){requestAnimationFrame(step);draw();return;}
  const ids=[...pos.keys()];
  const visible=ids.filter(id=>!isHidden(graph.nodes[id]));
  for(let i=0;i<visible.length;i++){
    const a=pos.get(visible[i]);
    for(let j=i+1;j<visible.length;j++){
      const b=pos.get(visible[j]);
      let dx=a.x-b.x,dy=a.y-b.y,d2=dx*dx+dy*dy||1;
      const f=2600/d2;
      const d=Math.sqrt(d2);
      a.vx+=dx/d*f; a.vy+=dy/d*f; b.vx-=dx/d*f; b.vy-=dy/d*f;
    }
  }
  for(const e of graph.edges){
    const a=pos.get(e.from),b=pos.get(e.to);
    if(!a||!b)continue;
    let dx=b.x-a.x,dy=b.y-a.y,d=Math.sqrt(dx*dx+dy*dy)||1;
    // contains edges (folder->child) want tight nesting so the filesystem
    // shape reads as fans, not as long chains. Other edges keep the wider
    // relationship-graph layout.
    const tight=e.rel==="contains";
    const target=tight?42:118;
    const k=tight?0.075:0.022;
    const f=(d-target)*k;
    a.vx+=dx/d*f; a.vy+=dy/d*f; b.vx-=dx/d*f; b.vy-=dy/d*f;
  }
  for(const id of ids){
    const p=pos.get(id);
    p.vx-=p.x*0.0045; p.vy-=p.y*0.0045;          // gravity to center
    if(p.fixed){p.vx=0;p.vy=0;continue;}
    p.vx*=0.86; p.vy*=0.86;
    p.x+=p.vx*alpha; p.y+=p.vy*alpha;
  }
  alpha*=0.985;
  draw();
  requestAnimationFrame(step);
}

function nodeRadius(id){
  const n=graph.nodes[id];
  let r=7+Math.min(degree(id),10)*1.1;
  if(n.type==="plan"||n.type==="milestone")r+=4;
  return r;
}
function degree(id){
  let d=0; for(const e of graph.edges)
    if(e.from===id||e.to===id)d++;
  return d;
}

function draw(){
  ctx.setTransform(devicePixelRatio,0,0,devicePixelRatio,0,0);
  ctx.clearRect(0,0,innerWidth,innerHeight);
  ctx.save();
  ctx.translate(innerWidth/2+cam.x,innerHeight/2+cam.y);
  ctx.scale(cam.s,cam.s);

  // edges
  for(const e of graph.edges){
    const a=pos.get(e.from),b=pos.get(e.to);
    if(!a||!b)continue;
    const na=graph.nodes[e.from],nb=graph.nodes[e.to];
    if(isHidden(na)||isHidden(nb))continue;
    const hl=selected&&(e.from===selected||e.to===selected);
    const isRead=e.rel==="reads";
    ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);
    ctx.strokeStyle=hl?cssVar("--accent")
      :isRead?cssVar("--file"):cssVar("--line");
    ctx.globalAlpha=hl?.9:isRead?.5:.55;
    ctx.lineWidth=(hl?1.6:1)/cam.s;
    if(e.rel==="depends_on"||e.rel==="blocks")ctx.setLineDash([4/cam.s,3/cam.s]);
    else if(isRead)ctx.setLineDash([1/cam.s,3/cam.s]);
    ctx.stroke(); ctx.setLineDash([]);
    if(hl){
      const mx=(a.x+b.x)/2,my=(a.y+b.y)/2;
      ctx.globalAlpha=1; ctx.fillStyle=cssVar("--accent");
      ctx.font="500 "+(9/cam.s)+"px Inter,-apple-system,sans-serif";
      ctx.textAlign="center"; ctx.fillText(e.rel,mx,my-3/cam.s);
    }
  }
  ctx.globalAlpha=1;

  // nodes
  for(const [id,p] of pos){
    const n=graph.nodes[id]; if(!n||hidden.has(n.type))continue;
    const tier=n.tier||"active";
    if(tier==="archive" && hidden.has("archive"))continue;
    const r=nodeRadius(id);
    const col=cssVar(typeColor(n));
    const isSel=id===selected, isHov=id===hover;
    const match=search&&n.title.toLowerCase().includes(search);
    const dim=search&&!match;
    const archDim=(tier==="archive")?0.32:1;
    ctx.globalAlpha=(dim?.2:1)*archDim;

    if(tier==="pinned"){
      ctx.beginPath(); ctx.arc(p.x,p.y,r+4,0,7);
      ctx.strokeStyle=cssVar("--question"); ctx.lineWidth=1.6/cam.s;
      ctx.stroke();
    }
    if(id===focusId){
      ctx.beginPath(); ctx.arc(p.x,p.y,r+5,0,7);
      ctx.strokeStyle=cssVar("--accent"); ctx.lineWidth=1.4/cam.s;
      ctx.setLineDash([2/cam.s,2/cam.s]); ctx.stroke(); ctx.setLineDash([]);
    }
    // pop-in: expanding ring when a node first appears
    if(popIds.has(id)){
      const age=performance.now()-(popClock.get(id)||0);
      if(age>1600){popIds.delete(id);popClock.delete(id);}
      else{
        const k=age/1600;
        ctx.beginPath();
        ctx.arc(p.x,p.y,r+3+k*26/cam.s,0,7);
        ctx.strokeStyle=cssVar("--accent");
        ctx.globalAlpha=(1-k)*0.7;
        ctx.lineWidth=2/cam.s; ctx.stroke();
        ctx.globalAlpha=dim?.2:1;
        alpha=Math.max(alpha,.06);
      }
    }
    if(isSel||isHov){
      ctx.beginPath(); ctx.arc(p.x,p.y,r+3.5,0,7);
      ctx.fillStyle=col; ctx.globalAlpha=dim?.2:.28; ctx.fill();
      ctx.globalAlpha=dim?.2:1;
    }
    ctx.beginPath(); ctx.arc(p.x,p.y,r,0,7);
    ctx.fillStyle=col; ctx.fill();
    if(n.type==="milestone"||n.type==="plan"){
      ctx.lineWidth=2/cam.s; ctx.strokeStyle=cssVar("--bg"); ctx.stroke();
    }
    // git-commit milestones get a dashed outer ring so they read as
    // "external/historical" rather than ordinary plan milestones.
    if(n.type==="milestone" && (n.tags||[]).indexOf("git")>=0){
      ctx.beginPath(); ctx.arc(p.x,p.y,r+3,0,7);
      ctx.strokeStyle=cssVar("--milestone");
      const prev=ctx.globalAlpha; ctx.globalAlpha=prev*0.6;
      ctx.lineWidth=1.2/cam.s;
      ctx.setLineDash([2/cam.s,2/cam.s]); ctx.stroke();
      ctx.setLineDash([]); ctx.globalAlpha=prev;
    }
    if(n.missing){
      ctx.strokeStyle=cssVar("--task-blocked"); ctx.lineWidth=2/cam.s;
      ctx.stroke();
    }
    if(cam.s>0.55||isSel||isHov||match){
      ctx.fillStyle=isSel?"#fff":cssVar("--ink");
      ctx.globalAlpha=dim?.25:1;
      ctx.font=(isSel?"600 ":"500 ")+((isSel?11:10)/cam.s)+
        "px Inter,-apple-system,sans-serif";
      ctx.textAlign="center";
      const t=n.title.length>26?n.title.slice(0,25)+"\u2026":n.title;
      ctx.fillText(t,p.x,p.y+r+11/cam.s);
    }
  }
  ctx.globalAlpha=1;

  // shift-drag link ghost
  if(linking){
    const a=pos.get(linking.from);
    if(a){
      const w=screenToWorld(linking.x,linking.y);
      ctx.beginPath(); ctx.moveTo(a.x,a.y);
      ctx.lineTo(w.x,w.y);
      ctx.strokeStyle=cssVar("--accent");
      ctx.globalAlpha=.85; ctx.lineWidth=1.6/cam.s;
      ctx.setLineDash([5/cam.s,4/cam.s]); ctx.stroke();
      ctx.setLineDash([]);
      ctx.beginPath(); ctx.arc(w.x,w.y,3/cam.s,0,7);
      ctx.fillStyle=cssVar("--accent"); ctx.fill();
      ctx.globalAlpha=1;
    }
  }
  ctx.restore();
}

// ---- hit testing ----
function screenToWorld(sx,sy){
  return {x:(sx-innerWidth/2-cam.x)/cam.s,y:(sy-innerHeight/2-cam.y)/cam.s};
}
function pick(sx,sy){
  const w=screenToWorld(sx,sy);
  let best=null,bd=1e9;
  for(const [id,p] of pos){
    const n=graph.nodes[id]; if(!n||isHidden(n))continue;
    const r=nodeRadius(id)+4;
    const d=(p.x-w.x)**2+(p.y-w.y)**2;
    if(d<r*r&&d<bd){bd=d;best=id;}
  }
  return best;
}

let linking=null;          // shift-drag to create an edge
cv.addEventListener("mousedown",e=>{
  const id=pick(e.clientX,e.clientY);
  if(id && e.shiftKey){
    linking={from:id,x:e.clientX,y:e.clientY};
    cv.style.cursor="crosshair";
  }else if(id){
    const p=pos.get(id);
    drag={id,p,fixedWas:p.fixed,moved:false};
    p.fixed=true;
  }else{
    panning={x:e.clientX,y:e.clientY,cx:cam.x,cy:cam.y};
  }
});
addEventListener("mousemove",e=>{
  if(linking){
    linking.x=e.clientX; linking.y=e.clientY;
    linking.over=pick(e.clientX,e.clientY);
  }else if(drag){
    const w=screenToWorld(e.clientX,e.clientY);
    drag.p.x=w.x; drag.p.y=w.y; drag.p.vx=0; drag.p.vy=0;
    drag.moved=true; alpha=Math.max(alpha,.3);
  }else if(panning){
    cam.x=panning.cx+(e.clientX-panning.x);
    cam.y=panning.cy+(e.clientY-panning.y);
  }else{
    const id=pick(e.clientX,e.clientY);
    hover=id;
    cv.style.cursor=id?(e.shiftKey?"crosshair":"pointer"):"default";
  }
});
addEventListener("mouseup",e=>{
  if(linking){
    const to=pick(e.clientX,e.clientY);
    if(to && to!==linking.from){ openLink(linking.from,to); }
    linking=null; cv.style.cursor="default";
  }else if(drag){
    if(!drag.moved){ selected=drag.id; openPanel(drag.id); }
    drag.p.fixed=drag.moved?true:drag.fixedWas;
    drag=null;
  }
  panning=null;
});
cv.addEventListener("dblclick",e=>{
  if(MODE!=="live")return;
  if(!pick(e.clientX,e.clientY))openAdd();
});
cv.addEventListener("wheel",e=>{
  e.preventDefault();
  const k=e.deltaY<0?1.12:0.89;
  const mx=e.clientX-innerWidth/2,my=e.clientY-innerHeight/2;
  cam.x=mx-(mx-cam.x)*k; cam.y=my-(my-cam.y)*k;
  cam.s=Math.min(3.5,Math.max(0.15,cam.s*k));
},{passive:false});

// ---- chrome ----
function renderChrome(){
  document.getElementById("proj").textContent=graph.meta.project||"";
  const ns=Object.values(graph.nodes);
  const tasks=ns.filter(n=>n.type==="task");
  const done=tasks.filter(n=>n.status==="done").length;
  document.getElementById("counts").innerHTML=
    "<b>"+ns.length+"</b> nodes &middot; <b>"+graph.edges.length+
    "</b> edges &middot; tasks <b>"+done+"/"+tasks.length+"</b>";
  const fs=document.getElementById("focusStat");
  if(focusId&&graph.nodes[focusId])
    fs.innerHTML="focus: <b>"+esc(graph.nodes[focusId].title)+"</b>";
  else fs.textContent="";

  const leg=document.getElementById("legend"); leg.innerHTML="";
  const items=[["plan","--plan"],["task","--task-doing"],["file","--file"],
    ["folder","--folder"],["decision","--decision"],["note","--note"],
    ["question","--question"],["milestone","--milestone"]];
  for(const [t,v] of items){
    const c=document.createElement("div");
    c.className="chip"+(hidden.has(t)?" off":"");
    c.innerHTML="<i style='background:"+cssVar(v)+"'></i>"+t;
    c.onclick=()=>{hidden.has(t)?hidden.delete(t):hidden.add(t);
      renderChrome();alpha=Math.max(alpha,.4);};
    leg.appendChild(c);
  }
  // tier toggle: only show if there are any archived nodes
  const anyArch=Object.values(graph.nodes).some(
    n=>(n.tier||"active")==="archive");
  if(anyArch){
    const c=document.createElement("div");
    c.className="chip"+(hidden.has("archive")?" off":"")+
      " tierchip";
    c.innerHTML="<i style='background:var(--faint)'></i>archive";
    c.title="show / hide archived nodes";
    c.onclick=()=>{
      hidden.has("archive")?hidden.delete("archive"):hidden.add("archive");
      renderChrome();alpha=Math.max(alpha,.4);};
    leg.appendChild(c);
  }
  if(document.getElementById("treepanel").classList.contains("open"))
    renderTree();
}
function esc(s){return (s||"").replace(/[&<>]/g,c=>(
  {"&":"&amp;","<":"&lt;",">":"&gt;"}[c]));}

let _toastTimer=null;
function toast(msg,kind,duration){
  // duration: ms before auto-dismiss; 0 = sticky (until another toast() call
  // replaces it or dismissToast()). Default 2200ms.
  const t=document.getElementById("toast"); if(!t)return;
  t.textContent=msg;
  t.className=""+(kind||"");
  void t.offsetWidth;
  t.classList.add("show");
  clearTimeout(_toastTimer);
  if(duration !== 0){
    _toastTimer=setTimeout(()=>t.classList.remove("show"),
      duration || 2200);
  }
}
function dismissToast(){
  const t=document.getElementById("toast"); if(!t)return;
  clearTimeout(_toastTimer);
  t.classList.remove("show");
}

// ---- tree panel ----
const treeCollapsed=new Set();       // folder ids the user has collapsed
let treeAutoCollapsed=false;          // first-render auto-collapse pass
let treeSearch="";

function renderTree(){
  const body=document.getElementById("treebody"); body.innerHTML="";
  const parentOf={}, childrenOf={};
  for(const e of graph.edges){
    if(e.rel==="contains"){
      parentOf[e.to]=e.from;
      (childrenOf[e.from]=childrenOf[e.from]||[]).push(e.to);
    }
  }
  const roots=[];
  for(const id in graph.nodes){
    const n=graph.nodes[id];
    if((n.type==="folder"||n.type==="file") && !parentOf[id])
      roots.push(id);
  }
  const cmp=(a,b)=>{
    const na=graph.nodes[a],nb=graph.nodes[b];
    if((na.type==="folder")!==(nb.type==="folder"))
      return na.type==="folder"?-1:1;
    return (na.title||"").localeCompare(nb.title||"");
  };
  roots.sort(cmp);

  // first-time: collapse folders that would dump a lot into the panel.
  // Keep top-level expanded; below that, collapse only folders whose
  // subtree exceeds AUTOCOLLAPSE_THRESHOLD. Shallow projects show
  // fully; deep dense ones stay manageable.
  if(!treeAutoCollapsed){
    treeAutoCollapsed=true;
    const AUTOCOLLAPSE_THRESHOLD=12;
    function descCount(id,memo){
      if(memo.has(id))return memo.get(id);
      let n=0;
      for(const k of (childrenOf[id]||[])){n++;n+=descCount(k,memo);}
      memo.set(id,n); return n;
    }
    const memo=new Map();
    for(const id in graph.nodes){
      const n=graph.nodes[id];
      if(n.type==="folder" && parentOf[id] &&
         descCount(id,memo) > AUTOCOLLAPSE_THRESHOLD){
        treeCollapsed.add(id);
      }
    }
  }

  // search: if active, find matches and force-expand their ancestor path
  let forceShow=null;
  if(treeSearch){
    const q=treeSearch.toLowerCase();
    forceShow=new Set();
    for(const id in graph.nodes){
      const n=graph.nodes[id];
      if((n.type==="folder"||n.type==="file") &&
         (n.title||"").toLowerCase().includes(q)){
        let cur=id;
        while(cur){
          forceShow.add(cur);
          if(treeCollapsed.has(cur)) treeCollapsed.delete(cur);
          cur=parentOf[cur];
        }
      }
    }
  }

  function countDescendants(id){
    let n=0;
    for(const k of (childrenOf[id]||[])){
      n++; n+=countDescendants(k);
    }
    return n;
  }

  function row(id,depth){
    const n=graph.nodes[id]; if(!n)return;
    if(forceShow && !forceShow.has(id))return;
    const tier=n.tier||"active";
    if(tier==="archive" && hidden.has("archive"))return;
    const r=document.createElement("div");
    r.className="trow"+(selected===id?" sel":"")+
      (tier==="archive"?" archived":"");
    r.style.paddingLeft=(4+depth*14)+"px";

    const chev=document.createElement("span");
    chev.className="tchev";
    const kids=childrenOf[id]||[];
    if(n.type==="folder" && kids.length){
      chev.textContent=treeCollapsed.has(id)?"▸":"▾";
      chev.onclick=ev=>{
        ev.stopPropagation();
        treeCollapsed.has(id)?treeCollapsed.delete(id):treeCollapsed.add(id);
        renderTree();
      };
    }else{ chev.textContent=""; }
    r.appendChild(chev);

    const dot=document.createElement("span");
    dot.className="tdot";
    dot.style.background=cssVar(typeColor(n));
    r.appendChild(dot);

    const t=document.createElement("span");
    t.className="ttitle";
    t.textContent=(n.type==="folder"?(n.title||"/"):n.title);
    r.appendChild(t);

    if(tier==="pinned"){
      const p=document.createElement("span");
      p.className="tpin"; p.textContent="★"; p.title="pinned";
      r.appendChild(p);
    }
    if(n.missing){
      const m=document.createElement("span");
      m.className="tmiss"; m.textContent="missing";
      r.appendChild(m);
    }
    if(n.type==="folder" && treeCollapsed.has(id) && kids.length){
      const c=document.createElement("span");
      c.className="tcount"; c.textContent=countDescendants(id);
      r.appendChild(c);
    }

    r.onclick=()=>{
      selected=id; openPanel(id); centerOn(id);
      cam.s=Math.max(cam.s,.9);
      renderTree();
    };
    body.appendChild(r);
    if(!treeCollapsed.has(id)){
      for(const k of kids.slice().sort(cmp)) row(k,depth+1);
    }
  }
  if(!roots.length){
    body.innerHTML="<div style='padding:14px 16px;color:var(--dim);"+
      "font-size:11px;line-height:1.5'>No folder/file nodes yet. "+
      "Run <code style='background:var(--panel2);padding:1px 5px;"+
      "border-radius:3px'>weave sync --scan</code> in your terminal "+
      "to import the project tree.</div>";
    return;
  }
  for(const id of roots) row(id,0);
}
