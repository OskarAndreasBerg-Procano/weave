    s.set_defaults(fn=cmd_attach)

    s = sub.add_parser("detach", help="remove a reading link")
    s.add_argument("node")
    s.add_argument("targets", nargs="+")
    s.set_defaults(fn=cmd_detach)

    s = sub.add_parser("context", help="show the reading list for a node")
    s.add_argument("node")
    s.add_argument("--json", action="store_true")
    s.set_defaults(fn=cmd_context)

    s = sub.add_parser("demo", help="seed an example graph")
    s.set_defaults(fn=cmd_demo)

    s = sub.add_parser("view", help="write a static graph.html snapshot")
    s.add_argument("--no-open", action="store_true")
    s.set_defaults(fn=cmd_view)

    s = sub.add_parser("serve", help="run the live browser workspace")
    s.add_argument("--port", type=int, default=4747)
    s.add_argument("--no-open", action="store_true")
    s.set_defaults(fn=cmd_serve)

    s = sub.add_parser("mcp", help="run the MCP server (stdio) for Claude")
    s.set_defaults(fn=cmd_mcp)

    s = sub.add_parser("_hook-session")
    s.set_defaults(fn=cmd_hook_session)
    s = sub.add_parser("_hook-postuse")
    s.set_defaults(fn=cmd_hook_postuse)
    s = sub.add_parser("_hook-pretool")
    s.set_defaults(fn=cmd_hook_pretool)
    return p


def main():
    parser = build_parser()
    args = parser.parse_args()
    if not getattr(args, "fn", None):
        parser.print_help()
        return
    args.fn(args)


if __name__ == "__main__":
    main()
