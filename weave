# --------------------------------------------------------------------------
# helpers
# --------------------------------------------------------------------------
def now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def short_ts(iso: str) -> str:
    try:
        d = datetime.fromisoformat(iso)
        return d.strftime("%m-%d %H:%M")
    except Exception:
        return iso[:16]


def new_id() -> str:
    return "n_" + uuid.uuid4().hex[:6]


def find_root(start: str = None):
    """Walk up from cwd to find the project root containing .weave/.

    Refuses to treat $HOME itself as a weave project: a `.weave/` directory
    sitting at the home root is almost always an accident (stale global-index
    collision from older versions, etc.) - real projects live under, not at,
    the user's home.
    """
    d = os.path.abspath(start or os.getcwd())
    home = os.path.abspath(os.path.expanduser("~"))
    while True:
        if os.path.isdir(os.path.join(d, WEAVE_DIRNAME)) and d != home:
            return d
        parent = os.path.dirname(d)
        if parent == d:
            return None
        d = parent


def die(msg: str, code: int = 1):
    sys.stderr.write("weave: " + msg + "\n")
    sys.exit(code)


def paths(root: str):
    w = os.path.join(root, WEAVE_DIRNAME)
    return {
        "weave": w,
        "graph": os.path.join(w, "graph.json"),
        "html": os.path.join(w, "graph.html"),
        "inbox": os.path.join(w, "inbox"),
        "outbox": os.path.join(w, "outbox"),
        "plans": os.path.join(w, "plans"),
        "focus": os.path.join(w, "focus"),
        "archive": os.path.join(w, "inbox", "_archive"),
        "versions": os.path.join(w, "versions"),
    }


VERSION_CAP = 50  # rotating snapshots kept in .weave/versions/


# --------------------------------------------------------------------------
# graph io
# --------------------------------------------------------------------------
def empty_graph(name: str) -> dict:
    return {
        "meta": {"project": name, "rev": 0, "created": now(), "schema": 1},
        "nodes": {},
        "edges": [],
        "log": [],
    }


def load_graph(root: str) -> dict:
    p = paths(root)["graph"]
    if not os.path.exists(p):
        return empty_graph(os.path.basename(root))
    with open(p, "r", encoding="utf-8") as f:
        g = json.load(f)
    g.setdefault("meta", {}).setdefault("rev", 0)
    g.setdefault("nodes", {})
    g.setdefault("edges", [])
    g.setdefault("log", [])
    return g


def save_graph(root: str, g: dict):
    p = paths(root)
    g["meta"]["rev"] = g["meta"].get("rev", 0) + 1
    g["meta"]["updated"] = now()
    gp = p["graph"]
    tmp = gp + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(g, f, indent=2, ensure_ascii=False)
    os.replace(tmp, gp)
    _snapshot_version(p["versions"], g)


def _snapshot_version(vdir: str, g: dict):
    """Write a snapshot of the just-saved graph and rotate to VERSION_CAP."""
    try:
        os.makedirs(vdir, exist_ok=True)
        rev = g["meta"].get("rev", 0)
        snap = os.path.join(vdir, "%07d.json" % rev)
        with open(snap, "w", encoding="utf-8") as f:
            json.dump(g, f, indent=2, ensure_ascii=False)
        files = sorted(f for f in os.listdir(vdir) if f.endswith(".json"))
        for old in files[:-VERSION_CAP]:
            try:
                os.remove(os.path.join(vdir, old))
            except OSError:
                pass
    except Exception:
        pass  # snapshotting must never break a save


def log_event(g: dict, actor: str, action: str, node: str = None):
    g["log"].append({"ts": now(), "actor": actor, "action": action,
                      "node": node})
    g["log"] = g["log"][-300:]


def resolve(g: dict, ref: str) -> str:
    """Resolve a node reference: exact id, id suffix, or title substring."""
    if not ref:
        die("empty node reference")
    if ref in g["nodes"]:
        return ref
    low = ref.lower()
    hits = []
    for nid, n in g["nodes"].items():
        if nid.endswith(ref) or low in n.get("title", "").lower():
            hits.append(nid)
    if len(hits) == 1:
        return hits[0]
    if not hits:
        die("no node matches '%s'" % ref)
    die("ambiguous '%s' -> %s" % (ref, ", ".join(
        "%s (%s)" % (h, g["nodes"][h].get("title", "")) for h in hits)))


def degree(g: dict, nid: str) -> int:
    return sum(1 for e in g["edges"] if e["from"] == nid or e["to"] == nid)


def get_focus(root: str):
    fp = paths(root)["focus"]
    if os.path.exists(fp):
        v = open(fp).read().strip()
        return v or None
    return None


def set_focus(root: str, nid):
    fp = paths(root)["focus"]
    if nid:
        open(fp, "w").write(nid)
    elif os.path.exists(fp):
        os.remove(fp)


def upsert_file_node(g: dict, root: str, relpath: str, actor: str) -> str:
    """Create or refresh a file node by path. Returns node id."""
    relpath = relpath.replace("\\", "/")
    for nid, n in g["nodes"].items():
        if n.get("type") == "file" and n.get("path") == relpath:
            ap = os.path.join(root, relpath)
            if os.path.exists(ap):
                n["hash"] = _file_hash(ap)
                n.pop("missing", None)
            n["updated"] = now()
            return nid
    nid = new_id()
    ap = os.path.join(root, relpath)
    g["nodes"][nid] = {
        "id": nid, "type": "file", "title": os.path.basename(relpath),
        "path": relpath, "body": "", "tags": [], "status": "",
        "author": actor, "created": now(), "updated": now(),
        "hash": _file_hash(ap) if os.path.exists(ap) else "",
    }
    return nid


def _file_hash(path: str) -> str:
    try:
        h = hashlib.sha1()
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(65536), b""):
                h.update(chunk)
        return h.hexdigest()[:12]
    except Exception:
        return ""


def add_edge(g: dict, src: str, dst: str, rel: str):
    for e in g["edges"]:
        if e["from"] == src and e["to"] == dst and e["rel"] == rel:
            return False
    g["edges"].append({"from": src, "to": dst, "rel": rel, "created": now()})
    return True


def _children(g: dict, nid: str, rel: str = "contains"):
    """Nodes reachable from nid via `rel` edges (one hop)."""
    return [e["to"] for e in g["edges"]
            if e["from"] == nid and e["rel"] == rel]


def expand_paths(g: dict, nid: str, seen=None):
    """Resolve a node to concrete file paths.

    file node  -> its path.
    folder node-> recurse through `contains` edges.
    other node -> recurse through its `reads` edges (so a plan's reading list
                  can itself reference sub-plans / tasks)."""
    if seen is None:
        seen = set()
    if nid in seen or nid not in g["nodes"]:
        return []
    seen.add(nid)
    n = g["nodes"][nid]
    t = n.get("type")
    if t == "file":
        return [n["path"]] if n.get("path") else []
    if t == "folder":
        out = []
        for c in _children(g, nid, "contains"):
            out += expand_paths(g, c, seen)
        return out
    # plan / task / milestone: follow its own reads edges
    out = []
    for c in _children(g, nid, "reads"):
        out += expand_paths(g, c, seen)
    return out


def reading_list(g: dict, nid: str):
    """Ordered, de-duplicated reading list for a task/plan node.

    Walks up implements-edges to inherit a parent plan's reading list, then
    adds the node's own `reads` targets. Returns list of (path, source_title)."""
    out, seen = [], set()

    def add_from(src_id):
        for tgt in _children(g, src_id, "reads"):
            label = g["nodes"].get(tgt, {}).get("title", tgt)
            for p in expand_paths(g, tgt):
                if p not in seen:
                    seen.add(p)
                    out.append((p, label))

    # inherited: parent plans reached via implements edges
    parents = [e["to"] for e in g["edges"]
               if e["from"] == nid and e["rel"] == "implements"]
    for p in parents:
        add_from(p)
    add_from(nid)
    return out


def _global_index_path():
    # MUST NOT be inside a `.weave/` directory: find_root() walks up looking
    # for `.weave/` and would otherwise treat $HOME as a weave project. So
    # use a plain dotfile in $HOME.
    return os.path.join(os.path.expanduser("~"), ".weave_index.json")


def _load_global_index():
    p = _global_index_path()
    # Best-effort migration from the old (broken) location.
    if not os.path.exists(p):
        legacy = os.path.join(os.path.expanduser("~"), ".weave", "index.json")
        if os.path.exists(legacy):
            try:
                shutil.copyfile(legacy, p)
            except Exception:
                pass
    if not os.path.exists(p):
        return {"projects": []}
    try:
        return json.load(open(p, encoding="utf-8"))
    except Exception:
        return {"projects": []}


def _save_global_index(idx):
    p = _global_index_path()
    try:
        os.makedirs(os.path.dirname(p), exist_ok=True)
        with open(p, "w", encoding="utf-8") as f:
            json.dump(idx, f, indent=2)
    except Exception:
        pass  # global registry is convenience; never block local work


def _port_alive(port, host="127.0.0.1", timeout=0.05):
    """Quick liveness probe for a local TCP port."""
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(timeout)
        try:
            return s.connect_ex((host, port)) == 0
        finally:
            s.close()
    except Exception:
        return False


def _register_project(root, name):
    """Add or refresh this project's entry in the cross-machine index."""
    idx = _load_global_index()
    root = os.path.abspath(root)
    existing = next((p for p in idx["projects"]
                     if os.path.abspath(p.get("path", "")) == root), None)
    if existing:
        existing["last_seen"] = now()
        existing["name"] = name
    else:
        idx["projects"].append({"path": root, "name": name,
                                 "first_seen": now(), "last_seen": now()})
    _save_global_index(idx)


def upsert_folder_node(g: dict, relpath: str) -> str:
    """Create or fetch a folder node by path. Returns node id."""
    relpath = relpath.replace("\\", "/").rstrip("/") or "."
    for nid, n in g["nodes"].items():
        if n.get("type") == "folder" and n.get("path") == relpath:
            return nid
    nid = new_id()
    title = "/" if relpath == "." else os.path.basename(relpath) + "/"
    g["nodes"][nid] = {
        "id": nid, "type": "folder", "title": title, "path": relpath,
        "body": "", "status": "", "tags": [], "author": "scan",
        "created": now(), "updated": now()}
    return nid


