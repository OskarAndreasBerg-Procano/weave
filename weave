def _inbox_files(root):
    d = paths(root)["inbox"]
    if not os.path.isdir(d):
        return []
    out = []
    for f in sorted(os.listdir(d)):
        fp = os.path.join(d, f)
        if os.path.isfile(fp) and not f.startswith("_") and f != "README.md":
            out.append(f)
    return out


def cmd_inbox(args):
    root = find_root() or die("not a weave project")
    p = paths(root)
    if args.file:
        src = os.path.join(p["inbox"], args.file)
        if not os.path.exists(src):
            die("no inbox file '%s'" % args.file)
        if args.done:
            os.makedirs(p["archive"], exist_ok=True)
            os.replace(src, os.path.join(
                p["archive"], time.strftime("%Y%m%d-") + args.file))
            print("archived %s" % args.file)
        else:
            print(open(src, encoding="utf-8").read())
        return
    files = _inbox_files(root)
    if not files:
        print("inbox empty")
        return
    for f in files:
        fp = os.path.join(p["inbox"], f)
        first = ""
        try:
            for line in open(fp, encoding="utf-8"):
                if line.strip():
                    first = line.strip()[:70]
                    break
        except Exception:
            pass
        print("%-28s %s" % (f, first))


