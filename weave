                       help="undo 'weave install' - removes user-scope "
                            "MCP + slash commands (keeps project graphs)")
    s.set_defaults(fn=cmd_uninstall)

    s = sub.add_parser("init", help="scaffold weave in this project")
    s.add_argument("--name")
    s.add_argument("--plugin", action="store_true",
                    help="skip writing local hooks/.mcp.json/commands - "
                         "use when the weave Claude Code plugin is installed")
    s.set_defaults(fn=cmd_init)

    s = sub.add_parser("add", help="add a node")
    s.add_argument("type", choices=NODE_TYPES)
