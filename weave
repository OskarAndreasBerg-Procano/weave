const searchResults=document.getElementById("searchresults");
const searchDeep=document.getElementById("searchDeep");
const searchGlobal=document.getElementById("searchGlobal");
let _searchTimer=null;

function showSearchResults(matches, isGlobal, total){
  searchResults.innerHTML="";
  if(!matches.length){
    searchResults.innerHTML="<div style='padding:10px 14px;"+
      "color:var(--dim);font-size:11px'>(no matches)</div>";
    searchResults.classList.add("open");
    return;
  }
  if(typeof total === "number" && total > matches.length){
    const h=document.createElement("div");
    h.style.cssText="padding:5px 14px;color:var(--faint);font-size:10px;"+
      "border-bottom:1px solid var(--line);letter-spacing:.04em;"+
      "text-transform:uppercase";
    h.textContent="showing "+matches.length+" of "+total+
      " - refine query to narrow";
    searchResults.appendChild(h);
  }
  matches.forEach(m=>{
    const r=document.createElement("div"); r.className="srow";
    r.innerHTML="<span class='sty'>"+esc(m.type||"?")+"</span>"+
      "<span class='stitle'>"+esc(m.title||m.id)+"</span>"+
      (isGlobal?
        "<span class='sproj'>"+esc(m.project||"")+
        (m.serve_port?" <span class='slive'>● live</span>":"")+
        "</span>":"");
    r.onclick=()=>{
      if(isGlobal){
        if(m.serve_port){
          window.open("http://127.0.0.1:"+m.serve_port+"/","_blank");
          toast("opening "+m.project+"...","ok");
        }else if(navigator.clipboard){
          navigator.clipboard.writeText(m.project_path);
          toast("copied "+m.project+" path (no live serve)","ok");
        }
      }else{
        selected=m.id; openPanel(m.id); centerOn(m.id);
        cam.s=Math.max(cam.s,.9);
      }
      searchResults.classList.remove("open");
    };
    searchResults.appendChild(r);
  });
  searchResults.classList.add("open");
}

function runApiSearch(){
  const q=searchEl.value.trim();
  if(!q){ searchResults.classList.remove("open"); return; }
  const params=new URLSearchParams({q:q,n:"20"});
  if(searchGlobal.checked) params.set("global","1");
  fetch("/api/search?"+params.toString()).then(r=>r.json())
    .then(d=>showSearchResults(d.matches||[], !!d.global, d.total));
}

searchEl.addEventListener("input",e=>{
  const q=e.target.value.trim();
  search=q.toLowerCase();
  // local in-memory: dim non-matching, fly to first hit (legacy behavior)
  if(search){
    const hit=Object.values(graph.nodes).find(
      n=>(n.title||"").toLowerCase().includes(search));
    if(hit){cam.s=Math.max(cam.s,.9);centerOn(hit.id);}
  }
  // deep/global: debounced API call with results dropdown
  clearTimeout(_searchTimer);
  if(searchDeep.checked || searchGlobal.checked){
    _searchTimer=setTimeout(runApiSearch, 220);
  }else{
    searchResults.classList.remove("open");
  }
});
