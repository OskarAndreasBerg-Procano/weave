// ---- actions menu (undo / history / sync / commit / re-layout) ----
function toggleActions(){
  const m=document.getElementById("actionsmenu");
  m.classList.toggle("open");
}
function closeActions(){
  document.getElementById("actionsmenu").classList.remove("open");
}
document.getElementById("actionsBtn").onclick=ev=>{
  ev.stopPropagation(); toggleActions();
};
addEventListener("click",ev=>{
  const m=document.getElementById("actionsmenu");
  const w=document.getElementById("actionswrap");
  if(m && m.classList.contains("open") && !w.contains(ev.target))
    m.classList.remove("open");
});
document.querySelectorAll("#actionsmenu .amrow").forEach(row=>{
  row.onclick=()=>{ closeActions(); doAction(row.dataset.act); };
});
function doAction(act){
  if(MODE!=="live"){ toast("workspace is read-only (static view)","err"); return;}
  if(act==="undo") doUndo();
  else if(act==="history") openHistory();
  else if(act==="sync") doSync({});
  else if(act==="scan") doSync({scan:true,tree:true});
  else if(act==="prune") doSync({prune_missing:true});
  else if(act==="commit") openCommit();
  else if(act==="relayout"){
    for(const p of pos.values())p.fixed=false; alpha=1;
  }
}
function doUndo(){
  op({op:"undo"}).then(r=>{
    if(r.error){ toast(r.error,"err"); return; }
    toast("undid to rev "+r.restored_rev+
          " ("+r.nodes+" nodes, "+r.edges+" edges)","ok");
  });
}
function doSync(args){
  const label=args.scan?"scanning project files...":
              args.prune_missing?"pruning missing files...":
              "syncing...";
  toast(label,"ok",0);  // sticky until response lands
  op(Object.assign({op:"sync"},args)).then(r=>{
    if(r.error){ toast(r.error,"err"); return; }
    toast(r.summary||"sync done","ok");
  });
}
function openHistory(){
  const ov=document.getElementById("history");
  ov.classList.add("open");
  const list=document.getElementById("histlist");
  list.innerHTML="<div style='padding:14px;color:var(--dim);"+
    "font-size:11px'>loading...</div>";
  fetch("/api/history?n=30").then(r=>r.json()).then(d=>{
    const items=d.history||[];
    if(!items.length){
      list.innerHTML="<div style='padding:14px;color:var(--dim);"+
        "font-size:11px'>(no snapshots yet)</div>";
      return;
    }
    list.innerHTML="";
    items.forEach(it=>{
      const r=document.createElement("div");
      r.style.cssText="display:flex;justify-content:space-between;"+
        "padding:7px 14px;border-bottom:1px solid var(--line);"+
        "font-size:11px;cursor:pointer;align-items:center;gap:10px";
      if(it.is_current) r.style.cssText+=";background:rgba(10,132,255,.10)";
      r.onmouseenter=()=>r.style.background="rgba(10,132,255,.18)";
      r.onmouseleave=()=>r.style.background=it.is_current?
        "rgba(10,132,255,.10)":"";
      r.innerHTML="<div><span style='font-family:JetBrains Mono,monospace;"+
        "color:var(--accent)'>rev "+it.rev+"</span>"+
        (it.is_current?" <span class='muted' style='font-size:9px'>(current)</span>":"")+
        "<div style='color:var(--dim);font-size:10px;margin-top:2px'>"+
        esc(it.last)+"</div></div>"+
        "<div style='color:var(--faint);font-size:10px;text-align:right'>"+
        it.nodes+" nodes<br>"+esc((it.ts||"").slice(11,16))+"</div>";
      r.onclick=()=>{
        if(it.is_current) return;
        if(!confirm("Restore rev "+it.rev+"? This becomes a new snapshot."))return;
        op({op:"undo",to:it.rev}).then(rr=>{
          if(rr.error){ toast(rr.error,"err"); return; }
          toast("restored rev "+it.rev,"ok");
          document.getElementById("history").classList.remove("open");
        });
      };
      list.appendChild(r);
    });
  });
}
document.getElementById("histClose").onclick=()=>
  document.getElementById("history").classList.remove("open");

function openCommit(){
  document.getElementById("cSha").value="";
  document.getElementById("cSince").value="";
  document.getElementById("commit").classList.add("open");
  setTimeout(()=>document.getElementById("cSha").focus(),50);
}
document.getElementById("cCancel").onclick=()=>
  document.getElementById("commit").classList.remove("open");
document.getElementById("cGo").onclick=()=>{
  const sha=document.getElementById("cSha").value.trim();
  const since=document.getElementById("cSince").value.trim();
  const args={op:"commit"};
  if(since) args.since=since;
  else if(sha) args.sha=sha;
  toast("linking commit...","ok",0);
  op(args).then(r=>{
    if(r.error){ toast(r.error,"err"); return; }
    // Format the CLI summary into something friendlier. Common shapes:
    //   "milestone n_xxx for git ABCDEFGH  subject text"
    //   "linked N commit(s)"
    //   "nothing new linked  (M already linked)"
    let msg=r.summary||"commit linked";
    let m=msg.match(/milestone\s+(n_\w+)\s+for\s+git\s+([0-9a-f]+)\s+(.*)/i);
    if(m) msg="linked git "+m[2]+" - "+m[3].replace(/\s*\(.*\)$/,"");
    else {
      m=msg.match(/linked\s+(\d+)\s+commit/);
      if(m) msg="linked "+m[1]+" commits";
    }
    toast(msg,"ok");
    document.getElementById("commit").classList.remove("open");
  });
};
