        esc(pp.name||"?")+(pp.is_self?" (this)":"")+liveBadge+
        "</div><div class='pp'>"+esc(pp.path)+"</div></div>"+
        "<div class='ps'>r"+pp.rev+" / "+pp.nodes+"n</div>";
