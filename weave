      const first=searchResults.querySelector(".srow");
      if(first){ first.click(); searchEl.blur(); return; }
    }
    const hit=Object.values(graph.nodes).find(
      n=>(n.title||"").toLowerCase().includes(q.toLowerCase()));
    if(hit){
      selected=hit.id; openPanel(hit.id); centerOn(hit.id);
      cam.s=Math.max(cam.s,.9);
      searchEl.blur();
    }else{
      toast("no match for \""+q+"\"","err");
