def _detect_python():
    """Pick the python command to use in hook/MCP wiring. Prefers python3,
    falls back to python, then to the Windows `py` launcher. Detection
    happens once per init - the chosen name is baked into the project's
    .claude/settings.local.json and .mcp.json so it doesn't drift."""
    for name in ("python3", "python", "py"):
        if shutil.which(name):
            return name
    return "python3"  # leave a clear failure target if nothing was found


