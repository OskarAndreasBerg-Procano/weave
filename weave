def cmd_install(args):
    """Register weave globally with Claude Code so weave_* MCP tools and
    /weave-* slash commands are available in every session, no per-project
    wiring. Idempotent."""
    here = SELF_PATH
    py = PY_CMD
    # 1. Register MCP server at user scope via the claude CLI
    claude = shutil.which("claude")
    if not claude:
        print("weave install: 'claude' CLI not on PATH. Install Claude "
              "Code from https://claude.com/code first, then re-run "
              "'weave install'.")
        return 1
    cmd = [claude, "mcp", "add", "--scope", "user", "weave", "--",
           py, here, "mcp"]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
    except Exception as e:
        print("weave install: failed to invoke claude mcp add: %s" % e)
        return 1
    if r.returncode != 0:
        err = (r.stderr or r.stdout or "").strip()
        # treat already-registered as success
        if "already" in err.lower() or "exists" in err.lower():
            print("- MCP server already registered at user scope")
        else:
            print("weave install: claude mcp add failed: %s" % err)
            return 1
    else:
        print("+ MCP server registered at user scope")

    # 2. Drop user-scope slash commands so /weave-* works everywhere
    home = os.path.expanduser("~")
    cmds_dir = os.path.join(home, ".claude", "commands")
    os.makedirs(cmds_dir, exist_ok=True)
    for fn, body in COMMANDS.items():
        with open(os.path.join(cmds_dir, fn), "w",
                  encoding="utf-8") as f:
            f.write(body + "\n")
    print("+ slash commands installed at %s" % cmds_dir)

    print()
    print("weave is ready. open Claude Code anywhere - the weave_* tools "
          "will be available.")
    print("in any project, run:  weave init    (creates .weave/graph.json)")
    return 0


def cmd_uninstall(args):
    """Remove the user-scope MCP registration and global slash commands.
    Does not touch per-project .weave/ graphs or .mcp.json files."""
    home = os.path.expanduser("~")
    claude = shutil.which("claude")
    if claude:
        cmd = [claude, "mcp", "remove", "--scope", "user", "weave"]
        try:
            r = subprocess.run(cmd, capture_output=True, text=True,
                               timeout=15)
            if r.returncode == 0:
                print("+ MCP server unregistered (user scope)")
            else:
                print("- MCP server: %s" %
                      ((r.stderr or r.stdout).strip() or "not registered"))
        except Exception as e:
            print("- MCP server: claude CLI error: %s" % e)
    else:
        print("- 'claude' CLI not found; skipping MCP unregister")
    cmds_dir = os.path.join(home, ".claude", "commands")
    removed = 0
    if os.path.isdir(cmds_dir):
        for fn in COMMANDS.keys():
            fp = os.path.join(cmds_dir, fn)
            try:
                os.remove(fp)
                removed += 1
            except OSError:
                pass
    print("+ %d user-scope slash command file(s) removed" % removed)
    print()
    print("weave uninstalled. per-project .weave/ graphs are untouched.")
    return 0


def cmd_init(args):
    root = find_root() or os.getcwd()
    p = paths(root)
    name = args.name or os.path.basename(root)
    fresh = not os.path.isdir(p["weave"])

    for d in [p["weave"], p["inbox"], p["outbox"], p["plans"], p["archive"]]:
        os.makedirs(d, exist_ok=True)
    if not os.path.exists(p["graph"]):
        save_graph(root, empty_graph(name))

    plugin_mode = getattr(args, "plugin", False)
    _write_claude_md(root, name)
    if not plugin_mode:
        _write_commands(root)
        _write_settings(root)
        _write_mcp_json(root)
    _write_gitignore(root)
    _register_project(root, name)

    readme = os.path.join(p["inbox"], "README.md")
    if not os.path.exists(readme):
        open(readme, "w").write(
            "# inbox\n\nDrop markdown files here for Claude. They surface in "
            "`weave inbox` and at session start.\nArchive processed ones with "
            "`weave inbox <file> --done`.\n")

    print("weave: %s '%s' at %s" % (
        "initialized" if fresh else "updated", name, p["weave"]))
    print("  graph    %s" % p["graph"])
    if plugin_mode:
        print("  plugin mode: hooks/mcp/commands provided by installed "
              "Claude Code plugin")
    else:
        print("  hooks    .claude/settings.local.json")
        print("  commands .claude/commands/weave-*.md")
        print("  mcp      .mcp.json  (native weave_* tools for Claude)")
    print("\nnext:  weave demo   then   weave serve")


def cmd_add(args):
    root = find_root() or die("not a weave project (run `weave init`)")
    g = load_graph(root)
    if args.type not in NODE_TYPES:
        die("type must be one of: " + ", ".join(NODE_TYPES))
    nid = new_id()
    status = args.status or ("todo" if args.type == "task"
                             else "open" if args.type == "question" else "")
    g["nodes"][nid] = {
        "id": nid, "type": args.type, "title": args.title,
        "body": args.body or "", "status": status,
        "tags": [t.strip() for t in (args.tags or "").split(",") if t.strip()],
        "path": args.path or "", "author": args.author,
        "tier": args.tier or "active",
        "created": now(), "updated": now(),
    }
    log_event(g, args.author, "add %s: %s" % (args.type, args.title), nid)
    if args.parent:
        pid = resolve(g, args.parent)
        rel = args.rel or ("implements" if args.type == "task" else "relates_to")
        add_edge(g, nid, pid, rel)
    save_graph(root, g)
    print(nid)


def cmd_link(args):
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    src, dst = resolve(g, args.src), resolve(g, args.dst)
    rel = args.rel
    if rel not in EDGE_RELS:
        sys.stderr.write("weave: note - '%s' is not a standard rel\n" % rel)
    if add_edge(g, src, dst, rel):
        log_event(g, "human", "link %s -%s-> %s" % (src, rel, dst))
        save_graph(root, g)
        print("linked %s -%s-> %s" % (src, rel, dst))
    else:
        print("edge already exists")


def cmd_unlink(args):
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    src, dst = resolve(g, args.src), resolve(g, args.dst)
    before = len(g["edges"])
    g["edges"] = [e for e in g["edges"] if not (
        e["from"] == src and e["to"] == dst and
        (args.rel is None or e["rel"] == args.rel))]
    if len(g["edges"]) < before:
        save_graph(root, g)
        print("removed %d edge(s)" % (before - len(g["edges"])))
    else:
        print("no matching edge")


def cmd_set(args):
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    nid = resolve(g, args.node)
    n = g["nodes"][nid]
    changed = []
    if args.status is not None:
        n["status"] = args.status
        changed.append("status=" + args.status)
    if args.title is not None:
        n["title"] = args.title
        changed.append("title")
    if args.body is not None:
        n["body"] = args.body
        changed.append("body")
    if args.tags is not None:
        n["tags"] = [t.strip() for t in args.tags.split(",") if t.strip()]
        changed.append("tags")
    if args.tier is not None:
        if args.tier not in TIERS:
            die("tier must be one of: " + ", ".join(TIERS))
        n["tier"] = args.tier
        changed.append("tier=" + args.tier)
    if not changed:
        die("nothing to set")
    n["updated"] = now()
    log_event(g, "human", "set %s [%s]" % (nid, ", ".join(changed)), nid)
    save_graph(root, g)
    print("updated %s: %s" % (nid, ", ".join(changed)))


def _set_tier(root, ref, tier):
    g = load_graph(root)
    nid = resolve(g, ref)
    n = g["nodes"][nid]
    n["tier"] = tier
    n["updated"] = now()
    log_event(g, "human", "tier %s -> %s" % (nid, tier), nid)
    save_graph(root, g)
    print("%s -> tier=%s" % (nid, tier))


def cmd_pin(args):
    """Mark a node as pinned (always-surfaced in SessionStart hook)."""
    root = find_root() or die("not a weave project")
    _set_tier(root, args.node, "pinned")


def cmd_archive(args):
    """Mark a node as archived (excluded from status / SessionStart hook)."""
    root = find_root() or die("not a weave project")
    _set_tier(root, args.node, "archive")


def cmd_unarchive(args):
    """Restore an archived or pinned node to the active tier."""
    root = find_root() or die("not a weave project")
    _set_tier(root, args.node, "active")


def cmd_rm(args):
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    nid = resolve(g, args.node)
    title = g["nodes"][nid].get("title", "")
    del g["nodes"][nid]
    g["edges"] = [e for e in g["edges"]
                  if e["from"] != nid and e["to"] != nid]
    log_event(g, "human", "remove %s: %s" % (nid, title))
    if get_focus(root) == nid:
        set_focus(root, None)
    save_graph(root, g)
    print("removed %s" % nid)


def cmd_focus(args):
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    if args.node is None:
        # no arg: show what's focused. don't silently clear important state -
        # require an explicit keyword for that.
        fid = get_focus(root)
        if fid and fid in g["nodes"]:
            n = g["nodes"][fid]
            print("focus: %s  %s" % (fid, n.get("title", "")))
        else:
            print("focus: (none)")
            print("  set:    weave focus <plan>")
            print("  clear:  weave focus clear")
        return
    if args.node in ("-", "none", "clear"):
        set_focus(root, None)
        print("focus cleared")
        return
    nid = resolve(g, args.node)
    set_focus(root, nid)
    print("focus: %s  %s" % (nid, g["nodes"][nid].get("title", "")))


def cmd_ls(args):
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    rows = []
    for nid, n in g["nodes"].items():
        if args.type and n.get("type") != args.type:
            continue
        if args.status and n.get("status") != args.status:
            continue
        if args.tag and args.tag not in n.get("tags", []):
            continue
        if args.tier and n.get("tier", "active") != args.tier:
            continue
        rows.append((nid, n))
    rows.sort(key=lambda r: r[1].get("updated", ""), reverse=True)
    if not rows:
        print("(no matching nodes)")
        return
    for nid, n in rows:
        st = (" [%s]" % n["status"]) if n.get("status") else ""
        tg = (" #" + ",".join(n["tags"])) if n.get("tags") else ""
        print("%-8s %-9s %s%s%s" % (
            nid, n.get("type", "?"), n.get("title", ""), st, tg))


def _search_graph(g, q):
    """Return [(nid, node)] for matches in g, newest-first."""
    qlow = q.lower()
    rows = []
    for nid, n in g["nodes"].items():
        hay = " ".join([n.get("title", ""), n.get("body", ""),
                        " ".join(n.get("tags", []))]).lower()
        if qlow in hay:
            rows.append((nid, n))
    rows.sort(key=lambda r: r[1].get("updated", ""), reverse=True)
    return rows


def _print_match(nid, n, q, indent=""):
    st = (" [%s]" % n["status"]) if n.get("status") else ""
    print("%s%-8s %-9s %s%s" % (
        indent, nid, n.get("type", "?"), n.get("title", ""), st))
    body = n.get("body", "")
    idx = body.lower().find(q.lower())
    if idx >= 0 and body:
        s = max(0, idx - 24)
        e = min(len(body), idx + len(q) + 56)
        snippet = body[s:e].replace("\n", " ").strip()
        if s > 0:
            snippet = "..." + snippet
        if e < len(body):
            snippet = snippet + "..."
        print(indent + "           " + snippet[:120])


def cmd_search(args):
    """Free-text search across node titles, bodies and tags. With --global
    searches every project in the cross-machine index."""
    if args.global_:
        idx = _load_global_index()
        projects = [pp for pp in idx.get("projects", [])
                    if os.path.isdir(os.path.join(pp.get("path", ""),
                                                   WEAVE_DIRNAME))]
        if not projects:
            print("(no projects registered for global search)")
            return
        total = 0
        for pp in projects:
            try:
                g = json.load(open(os.path.join(pp["path"], WEAVE_DIRNAME,
                                                 "graph.json"),
                                    encoding="utf-8"))
            except Exception:
                continue
            rows = _search_graph(g, args.query)
            if not rows:
                continue
            print("=== %s  (%d match%s) ===" % (
                pp.get("name", "?"), len(rows),
                "" if len(rows) == 1 else "es"))
            for nid, n in rows[:args.n]:
                _print_match(nid, n, args.query, indent="  ")
            total += len(rows)
        if total == 0:
            print("(no matches for '%s' across %d project(s))" % (
                args.query, len(projects)))
        return
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    rows = _search_graph(g, args.query)
    if not rows:
        print("(no matches for '%s')" % args.query)
        return
    print("%d match%s for '%s'" % (
        len(rows), "" if len(rows) == 1 else "es", args.query))
    for nid, n in rows[:args.n]:
        _print_match(nid, n, args.query)


