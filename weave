def _write_claude_md(root, name):
    fp = os.path.join(root, "CLAUDE.md")
    block = CLAUDE_BLOCK.replace("WEAVE", WEAVE_CMD)
    existing = ""
    if os.path.exists(fp):
        existing = open(fp, encoding="utf-8").read()
    if "<!-- weave:start -->" in existing:
        pre = existing.split("<!-- weave:start -->")[0]
        post = existing.split("<!-- weave:end -->", 1)
        post = post[1] if len(post) > 1 else ""
        new = pre.rstrip() + "\n\n" + block + post
    elif existing.strip():
        new = existing.rstrip() + "\n\n" + block
    else:
        new = "# %s\n\n%s" % (name, block)
    open(fp, "w", encoding="utf-8").write(new)


def _write_commands(root):
    d = os.path.join(root, ".claude", "commands")
    os.makedirs(d, exist_ok=True)
    for fn, body in COMMANDS.items():
        open(os.path.join(d, fn), "w", encoding="utf-8").write(body + "\n")


def _write_settings(root):
    d = os.path.join(root, ".claude")
    os.makedirs(d, exist_ok=True)
    fp = os.path.join(d, "settings.local.json")
    s = {}
    if os.path.exists(fp):
        try:
            s = json.load(open(fp, encoding="utf-8"))
        except Exception:
            s = {}
    hooks = s.setdefault("hooks", {})

    sess_cmd = '%s _hook-session' % WEAVE_CMD
    post_cmd = '%s _hook-postuse' % WEAVE_CMD
    pre_cmd = '%s _hook-pretool' % WEAVE_CMD

    def has(events, cmd):
        for grp in events:
            for h in grp.get("hooks", []):
                if h.get("command") == cmd:
                    return True
        return False

    sess = hooks.setdefault("SessionStart", [])
    if not has(sess, sess_cmd):
        sess.append({"hooks": [{"type": "command", "command": sess_cmd}]})

    post = hooks.setdefault("PostToolUse", [])
    if not has(post, post_cmd):
        post.append({"matcher": "Write|Edit|MultiEdit",
                     "hooks": [{"type": "command", "command": post_cmd}]})

    pre = hooks.setdefault("PreToolUse", [])
    if not has(pre, pre_cmd):
        pre.append({"matcher": "*",
                    "hooks": [{"type": "command", "command": pre_cmd}]})

    open(fp, "w", encoding="utf-8").write(json.dumps(s, indent=2) + "\n")


def _write_mcp_json(root):
    fp = os.path.join(root, ".mcp.json")
    cfg = {}
    if os.path.exists(fp):
        try:
            cfg = json.load(open(fp, encoding="utf-8"))
        except Exception:
            cfg = {}
    servers = cfg.setdefault("mcpServers", {})
    servers["weave"] = {"command": PY_CMD, "args": [SELF_PATH, "mcp"]}
    open(fp, "w", encoding="utf-8").write(json.dumps(cfg, indent=2) + "\n")


def _write_gitignore(root):
    fp = os.path.join(root, ".gitignore")
    lines = []
    if os.path.exists(fp):
        lines = open(fp, encoding="utf-8").read().splitlines()
    want = [".weave/graph.html", ".weave/inbox/_archive/",
            ".weave/.seen_rev", ".weave/.seen_session", ".weave/.serve",
            ".weave/versions/",
            ".claude/settings.local.json", ".mcp.json"]
    add = [w for w in want if w not in lines]
    if add:
        with open(fp, "a", encoding="utf-8") as f:
            if lines and lines[-1].strip():
                f.write("\n")
            f.write("# weave\n" + "\n".join(add) + "\n")


