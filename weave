def _run_cmd(fn, **kw):
    """Invoke an existing cmd_ function, capturing its output as text."""
    ns = argparse.Namespace(**kw)
    out, errbuf = io.StringIO(), io.StringIO()
    is_err = False
    try:
        with contextlib.redirect_stdout(out), contextlib.redirect_stderr(errbuf):
            fn(ns)
    except SystemExit:
        is_err = True
    except Exception as e:
        errbuf.write("weave: " + str(e))
        is_err = True
    text = (out.getvalue() + errbuf.getvalue()).strip()
    return text or "(done)", is_err


def _mcp_dispatch(name, a):
    a = a or {}
    if name == "weave_status":
        return _run_cmd(cmd_status)
    if name == "weave_inbox":
        return _run_cmd(cmd_inbox, file=None, done=False)
    if name == "weave_add":
        if a.get("type") not in NODE_TYPES:
            return ("error: type must be one of " + ", ".join(NODE_TYPES),
                    True)
        return _run_cmd(cmd_add, type=a.get("type"), title=a.get("title", ""),
                        body=a.get("body"), tags=a.get("tags"),
                        status=a.get("status"), path=None,
                        parent=a.get("parent"), rel=a.get("rel"),
                        author="claude")
    if name == "weave_set":
        return _run_cmd(cmd_set, node=a.get("node"), status=a.get("status"),
                        title=a.get("title"), body=a.get("body"),
                        tags=a.get("tags"))
    if name == "weave_link":
        return _run_cmd(cmd_link, src=a.get("from"), dst=a.get("to"),
                        rel=a.get("rel"))
    if name == "weave_focus":
        return _run_cmd(cmd_focus, node=a.get("node") or None)
    if name == "weave_ls":
        return _run_cmd(cmd_ls, type=a.get("type"), status=a.get("status"),
                        tag=a.get("tag"))
    if name == "weave_show":
        return _run_cmd(cmd_show, node=a.get("node"))
    if name == "weave_attach":
        tg = a.get("targets") or []
        if isinstance(tg, str):
            tg = [tg]
        return _run_cmd(cmd_attach, node=a.get("node"), targets=tg)
    if name == "weave_context":
        return _run_cmd(cmd_context, node=a.get("node"), json=False)
    if name == "weave_ask":
        return _run_cmd(cmd_add, type="question",
                        title=a.get("question", ""), body=a.get("body"),
                        tags=None, status=None, path=None,
                        parent=a.get("parent"), rel=None, author="claude")
    return ("unknown tool: " + str(name), True)


def _rpc_ok(mid, result):
    return {"jsonrpc": "2.0", "id": mid, "result": result}


def _rpc_err(mid, code, msg):
    return {"jsonrpc": "2.0", "id": mid,
            "error": {"code": code, "message": msg}}


def _handle_rpc(msg):
    if not isinstance(msg, dict):
        return None
    mid = msg.get("id")
    method = msg.get("method")
    params = msg.get("params") or {}
    if method == "initialize":
        return _rpc_ok(mid, {
            "protocolVersion": params.get("protocolVersion", "2025-06-18"),
            "capabilities": {"tools": {}},
            "serverInfo": {"name": "weave", "version": "1.0.0"}})
    if method and method.startswith("notifications/"):
        return None
    if method == "ping":
        return _rpc_ok(mid, {})
    if method == "tools/list":
        return _rpc_ok(mid, {"tools": MCP_TOOLS})
    if method == "tools/call":
        try:
            text, is_err = _mcp_dispatch(params.get("name"),
                                         params.get("arguments"))
        except Exception as e:
            text, is_err = "weave error: " + str(e), True
        return _rpc_ok(mid, {"content": [{"type": "text", "text": text}],
                             "isError": bool(is_err)})
    if mid is not None:
        return _rpc_err(mid, -32601, "method not found: " + str(method))
    return None


def cmd_mcp(args):
    """Run the weave MCP server over stdio. Launched by Claude Code."""
    sys.stderr.write("weave: mcp server ready\n")
    sys.stderr.flush()
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except Exception:
            continue
        if isinstance(msg, list):                       # JSON-RPC batch
            batch = [r for r in (_handle_rpc(m) for m in msg)
                     if r is not None]
            if batch:
                sys.stdout.write(json.dumps(batch) + "\n")
                sys.stdout.flush()
            continue
        try:
            resp = _handle_rpc(msg)
        except Exception as e:
            resp = _rpc_err(msg.get("id"), -32603, str(e))
        if resp is not None:
            sys.stdout.write(json.dumps(resp) + "\n")
            sys.stdout.flush()


