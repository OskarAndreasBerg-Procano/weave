def cmd_projects(args):
    """List/manage the cross-machine weave project index (~/.weave_index.json)."""
    idx = _load_global_index()
    if args.add:
        root = os.path.abspath(args.add)
        if not os.path.isdir(os.path.join(root, WEAVE_DIRNAME)):
            die("not a weave project (no .weave/): %s" % root)
        try:
            g = json.load(open(os.path.join(root, WEAVE_DIRNAME, "graph.json"),
                               encoding="utf-8"))
            name = g.get("meta", {}).get("project", os.path.basename(root))
        except Exception:
            name = os.path.basename(root)
        _register_project(root, name)
        print("registered: %s  (%s)" % (name, root))
        return
    if args.remove:
        target = os.path.abspath(args.remove)
        before = len(idx["projects"])
        idx["projects"] = [p for p in idx["projects"]
                           if os.path.abspath(p.get("path", "")) != target]
        _save_global_index(idx)
        print("removed %d project(s)" % (before - len(idx["projects"])))
        return
    if args.prune:
        before = len(idx["projects"])
        idx["projects"] = [p for p in idx["projects"]
                           if os.path.isdir(os.path.join(p.get("path", ""),
                                                          WEAVE_DIRNAME))]
        _save_global_index(idx)
        print("pruned %d stale entries" % (before - len(idx["projects"])))
        return
    projects = idx.get("projects", [])
    if not projects:
        print("(no weave projects registered yet)")
        print("they auto-register on `weave init`; add manually with "
              "`weave projects --add <path>`")
        return
    print("%-28s %-12s %-9s %s" % ("name", "rev/nodes", "focus", "path"))
    for p in sorted(projects, key=lambda x: x.get("last_seen", ""),
                    reverse=True):
        rp = p.get("path", "")
        gp = os.path.join(rp, WEAVE_DIRNAME, "graph.json")
        stats, focus_title = "(missing)", ""
        if os.path.exists(gp):
            try:
                g = json.load(open(gp, encoding="utf-8"))
                stats = "r%d/%dn" % (g["meta"].get("rev", 0), len(g["nodes"]))
                fp = os.path.join(rp, WEAVE_DIRNAME, "focus")
                if os.path.exists(fp):
                    fid = open(fp).read().strip()
                    if fid in g["nodes"]:
                        focus_title = g["nodes"][fid].get("title", "")[:9]
            except Exception:
                pass
        print("%-28s %-12s %-9s %s" % (
            p.get("name", "?")[:28], stats, focus_title, rp))


def _git(root, *args):
    try:
        return subprocess.run(["git", "-C", root] + list(args),
                              capture_output=True, text=True, timeout=15)
    except (FileNotFoundError, OSError) as e:
        die("git not available: %s" % e)


def _link_one_commit(g, root, sha, fid, file_by_path):
    """Link a single git commit as a milestone in g. Returns (nid, action)
    where action is 'created', 'skipped' (already linked), or 'missing'."""
    r = _git(root, "log", "-1",
             "--format=%H%x1f%s%x1f%an%x1f%ad", "--date=short", sha)
    if r.returncode != 0:
        return (None, "missing")
    parts = r.stdout.strip().split("\x1f")
    if len(parts) < 4:
        return (None, "missing")
    full_sha, subject, author, date = parts[0], parts[1], parts[2], parts[3]
    short = full_sha[:8]
    for nid, n in g["nodes"].items():
        if n.get("type") == "milestone" and n.get("path") == full_sha:
            return (nid, "skipped")
    nid = new_id()
    g["nodes"][nid] = {
        "id": nid, "type": "milestone",
        "title": "[%s] %s" % (short, subject[:80]),
        "body": "git commit %s\nauthor: %s\ndate: %s\n\n%s" % (
            full_sha, author, date, subject),
        "status": "", "tags": ["git", short], "path": full_sha,
        "author": "claude", "tier": "active",
        "created": now(), "updated": now(),
    }
    log_event(g, "claude",
              "git-link: %s %s" % (short, subject[:60]), nid)
    if fid and fid in g["nodes"]:
        add_edge(g, nid, fid, "relates_to")
    # Link to file nodes whose path appears in this commit's diff. Create
    # file nodes for paths not yet tracked (so the milestone never points
    # into thin air), but skip noise: weave's own dirs, build output,
    # extensionless dotfiles like .gitignore.
    rf = _git(root, "show", "--pretty=", "--name-only", full_sha)
    if rf.returncode == 0:
        files_changed = [ln.strip().replace("\\", "/")
                         for ln in rf.stdout.strip().split("\n") if ln.strip()]
        for fp in files_changed:
            if fp.startswith(WEAVE_DIRNAME + "/") or fp == WEAVE_DIRNAME:
                continue
            parts = fp.split("/")
            if any(p in SKIP_DIRS for p in parts):
                continue
            ext = os.path.splitext(fp)[1].lower()
            if ext not in SCAN_EXTS:
                # if the file is already tracked, still link to it
                if fp not in file_by_path:
                    continue
            tgt = file_by_path.get(fp)
            if not tgt:
                tgt = upsert_file_node(g, root, fp, "git")
                file_by_path[fp] = tgt
            add_edge(g, nid, tgt, "produces")
    return (nid, "created")


def cmd_commit(args):
    """Link git commit(s) as milestone node(s) in the graph.

    Default: HEAD only.
    --since <ref>: every commit reachable in <ref>..HEAD (oldest first).
    Each milestone gets `relates_to` -> focus plan, and `produces` edges
    to any file nodes whose paths the commit touched."""
    root = find_root() or die("not a weave project")
    if args.since:
        r = _git(root, "rev-list", "--reverse", "%s..HEAD" % args.since)
        if r.returncode != 0:
            die("git: %s" % (r.stderr.strip() or "rev-list failed"))
        shas = [s for s in r.stdout.strip().split("\n") if s]
        if not shas:
            print("no commits in %s..HEAD" % args.since)
            return
    else:
        shas = [args.sha or "HEAD"]
    g = load_graph(root)
    fid = get_focus(root)
    file_by_path = {n.get("path"): nid
                    for nid, n in g["nodes"].items()
                    if n.get("type") == "file" and n.get("path")}
    created = skipped = 0
    last_nid = last_short = None
    for sha in shas:
        nid, action = _link_one_commit(g, root, sha, fid, file_by_path)
        if action == "created":
            created += 1
            last_nid = nid
            last_short = g["nodes"][nid].get("path", "")[:8]
        elif action == "skipped":
            skipped += 1
    if created or skipped:
        save_graph(root, g)
    extra = "  (%d already linked)" % skipped if skipped else ""
    if created == 1:
        print("milestone %s for git %s  %s%s" % (
            last_nid, last_short,
            g["nodes"][last_nid].get("title", "")[:60], extra))
    elif created == 0:
        print("nothing new linked%s" % extra)
    else:
        print("linked %d commit(s)%s" % (created, extra))


def cmd_history(args):
    """Recent graph snapshots (one written per save, oldest rotated out)."""
    root = find_root() or die("not a weave project")
    vdir = paths(root)["versions"]
    files = _list_versions(vdir)
    if not files:
        print("(no version history yet; snapshots are written on each save)")
        return
    rows = files[-args.n:][::-1]
    print("%-7s %-16s %s" % ("rev", "saved", "last action"))
    for f in rows:
        rev = int(f.split(".")[0])
        fp = os.path.join(vdir, f)
        try:
            mt = datetime.fromtimestamp(os.path.getmtime(fp))
            g = json.load(open(fp, encoding="utf-8"))
            log = g.get("log", [])
            last = log[-1].get("action", "") if log else ""
        except Exception:
            mt, last = None, ""
        ts = mt.strftime("%m-%d %H:%M") if mt else "?"
        print("%-7d %-16s %s" % (rev, ts, last[:80]))


def cmd_undo(args):
    """Restore the previous graph snapshot. With --to <rev>, jump to that
    snapshot specifically. The restored state is itself saved (and snapshot),
    so undo is reversible: re-`undo` keeps walking back; you can also undo
    --to a more-recent rev to redo."""
    root = find_root() or die("not a weave project")
    p = paths(root)
    vdir = p["versions"]
    files = _list_versions(vdir)
    if not files:
        die("no version history yet - nothing to undo")
    cur = load_graph(root)
    cur_rev = cur["meta"].get("rev", 0)

    if args.to is not None:
        target = "%07d.json" % args.to
        if target not in files:
            die("no snapshot for rev %d (try `weave history`)" % args.to)
    else:
        # walk back from current rev to find the most-recent earlier snapshot
        target = None
        for f in reversed(files):
            if int(f.split(".")[0]) < cur_rev:
                target = f
                break
        if target is None:
            die("no earlier snapshot to undo to "
                "(current rev %d)" % cur_rev)

    g = json.load(open(os.path.join(vdir, target), encoding="utf-8"))
    restored_rev = g["meta"].get("rev", 0)
    # let save_graph bump rev forward; preserve restored content
    g["meta"]["rev"] = cur_rev
    log_event(g, args.actor or "human",
              "undo: restored rev %d" % restored_rev)
    save_graph(root, g)
    print("undo: restored rev %d (new rev %d, %d nodes, %d edges)" % (
        restored_rev, g["meta"]["rev"], len(g["nodes"]), len(g["edges"])))


def cmd_sync(args):
    """Refresh file nodes. --scan imports all source files; --tree builds
    folder nodes mirroring the directory tree; --prune-missing removes nodes
    whose files no longer exist on disk. --scan also detects renames by
    matching the content hash of new files to nodes already marked missing."""
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    refreshed = missing = added = folders = renamed = pruned = 0

    for nid, n in list(g["nodes"].items()):
        if n.get("type") != "file" or not n.get("path"):
            continue
        ap = os.path.join(root, n["path"])
        if os.path.exists(ap):
            h = _file_hash(ap)
            if h != n.get("hash"):
                n["hash"] = h
                n["updated"] = now()
                refreshed += 1
            n.pop("missing", None)
        else:
            if not n.get("missing"):
                n["missing"] = True
                missing += 1

    build_tree = args.tree or args.scan
    if args.scan:
        existing = {n["path"]: n for n in g["nodes"].values()
                    if n.get("type") == "file"}
        # hash -> [missing nodes]: used for rename detection (same content,
        # new location). Skip empty/missing hashes.
        missing_by_hash = {}
        for n in existing.values():
            h = n.get("hash")
            if n.get("missing") and h:
                missing_by_hash.setdefault(h, []).append(n)

        count = 0
        for dirpath, dirnames, filenames in os.walk(root):
            dirnames[:] = [d for d in dirnames
                           if d not in SKIP_DIRS and not d.startswith(".")]
            for fn in filenames:
                if os.path.splitext(fn)[1].lower() not in SCAN_EXTS:
                    continue
                rel = os.path.relpath(os.path.join(dirpath, fn), root)
                rel = rel.replace("\\", "/")
                if rel in existing:
                    continue
                count += 1
                if count > 3000:
                    sys.stderr.write("weave: scan cap reached (3000)\n")
                    break
                # Rename detection: if the new file's hash matches exactly
                # one missing node, repoint that node instead of creating
                # a new one. Preserves all edges (reading lists etc).
                h = _file_hash(os.path.join(dirpath, fn))
                cand = missing_by_hash.get(h, []) if h else []
                if len(cand) == 1:
                    n = cand[0]
                    old = n["path"]
                    n["path"] = rel
                    n["title"] = os.path.basename(rel)
                    n.pop("missing", None)
                    n["updated"] = now()
                    log_event(g, "claude", "rename: %s -> %s" % (old, rel),
                              n["id"])
                    missing_by_hash[h] = []
                    renamed += 1
                else:
                    upsert_file_node(g, root, rel, "scan")
                    added += 1
            if count > 3000:
                break

    if args.prune_missing:
        gone = [nid for nid, n in g["nodes"].items()
                if n.get("type") == "file" and n.get("missing")]
        for nid in gone:
            del g["nodes"][nid]
        if gone:
            g["edges"] = [e for e in g["edges"]
                          if e["from"] not in gone and e["to"] not in gone]
        pruned = len(gone)

    if build_tree:
        folders = _rebuild_tree(g, root)

    still_missing = sum(1 for n in g["nodes"].values()
                        if n.get("type") == "file" and n.get("missing"))

    summary = ("sync: +%d files" % added) + (
        (", %d renamed" % renamed) if renamed else "") + (
        (", %d refreshed" % refreshed) if refreshed else "") + (
        (", %d pruned" % pruned) if pruned else "") + (
        (", %d folders" % folders) if folders else "")
    log_event(g, "claude", summary)
    save_graph(root, g)
    print(summary + ((" (%d still missing)" % still_missing)
                     if still_missing else ""))


def _rebuild_tree(g: dict, root: str) -> int:
    """Create folder nodes for every directory holding tracked files, and
    `contains` edges parent->child. Returns folder node count."""
    file_nodes = [(nid, n) for nid, n in g["nodes"].items()
                  if n.get("type") == "file" and n.get("path")]
    dirs = set()
    for _, n in file_nodes:
        d = os.path.dirname(n["path"])
        while True:
            dirs.add(d or ".")
            if not d:
                break
            d = os.path.dirname(d)
    folder_id = {}
    for d in dirs:
        folder_id[d or "."] = upsert_folder_node(g, d or ".")
    # drop folder nodes no longer backed by tracked files
    for nid, n in list(g["nodes"].items()):
        if n.get("type") == "folder" and n.get("path") not in folder_id:
            del g["nodes"][nid]
            g["edges"] = [e for e in g["edges"]
                          if e["from"] != nid and e["to"] != nid]
    # parent folder -> child folder
    for d, fid in folder_id.items():
        if d == ".":
            continue
        parent = os.path.dirname(d) or "."
        if parent in folder_id:
            add_edge(g, folder_id[parent], fid, "contains")
    # folder -> file
    for nid, n in file_nodes:
        d = os.path.dirname(n["path"]) or "."
        if d in folder_id:
            add_edge(g, folder_id[d], nid, "contains")
    return len(folder_id)


def cmd_attach(args):
    """Route files/folders to a task or plan: edge <node> -reads-> <target>."""
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    nid = resolve(g, args.node)
    attached = []
    for tref in args.targets:
        tid = _resolve_target(g, root, tref)
        if add_edge(g, nid, tid, "reads"):
            attached.append(g["nodes"][tid].get("title", tid))
    log_event(g, "human", "attach %d -> %s" % (len(attached), nid), nid)
    save_graph(root, g)
    if attached:
        print("attached to %s: %s" % (nid, ", ".join(attached)))
    else:
        print("nothing new attached")


def cmd_detach(args):
    root = find_root() or die("not a weave project")
    g = load_graph(root)
    nid = resolve(g, args.node)
    removed = 0
    for tref in args.targets:
        tid = _resolve_target(g, root, tref, create=False)
        before = len(g["edges"])
        g["edges"] = [e for e in g["edges"] if not (
            e["from"] == nid and e["to"] == tid and e["rel"] == "reads")]
        removed += before - len(g["edges"])
    save_graph(root, g)
    print("detached %d reading link(s) from %s" % (removed, nid))


def _resolve_target(g, root, ref, create=True):
    """Resolve an attach target: existing node, or a real file path that
    gets turned into a file node on the fly."""
    if ref in g["nodes"]:
        return ref
    cand = ref.replace("\\", "/").rstrip("/")
    ap = os.path.join(root, cand)
    if os.path.isfile(ap):
        return upsert_file_node(g, root, cand, "human")
    if os.path.isdir(ap):
        if create:
            _rebuild_tree(g, root)
        return upsert_folder_node(g, cand)
    return resolve(g, ref)


