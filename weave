    s.add_argument("--tier", choices=TIERS,
                   help="memory tier (default 'active')")
    s.set_defaults(fn=cmd_add)

    s = sub.add_parser("link", help="add an edge: weave link FROM TO REL")
    s.add_argument("src")
    s.add_argument("dst")
    s.add_argument("rel")
    s.set_defaults(fn=cmd_link)

    s = sub.add_parser("unlink", help="remove an edge")
    s.add_argument("src")
    s.add_argument("dst")
    s.add_argument("rel", nargs="?")
    s.set_defaults(fn=cmd_unlink)

    s = sub.add_parser("set", help="update a node")
    s.add_argument("node")
    s.add_argument("--status")
    s.add_argument("--title")
    s.add_argument("--body")
    s.add_argument("--tags")
    s.add_argument("--tier", choices=TIERS)
